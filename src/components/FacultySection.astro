    // Adjusted Scroll Amount for new Card Size
    const scrollAmount = window.innerWidth < 768 ? 180 : 300; 

    // Click Handler
    scrollBtn.addEventListener('click', () => {
        const maxScrollLeft = scrollContainer.scrollWidth - scrollContainer.clientWidth;
        
        if (scrollContainer.scrollLeft >= maxScrollLeft - 10) {
            scrollContainer.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
            scrollContainer.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        }
    });

    // Scroll Monitor
    scrollContainer.addEventListener('scroll', () => {
        const maxScrollLeft = scrollContainer.scrollWidth - scrollContainer.clientWidth;
        
        if (scrollContainer.scrollLeft >= maxScrollLeft - 10) {
            scrollIcon.style.transform = 'rotate(180deg)';
        } else {
            scrollIcon.style.transform = 'rotate(0deg)';
        }
    });
  </script>
</section>