---
import { Image } from 'astro:assets';

// -----------------------------------------------------------------
// STEP 1: JAB PHOTOS AA JAYE TO INHE UNCOMMENT KAREIN
// -----------------------------------------------------------------
// import gallery1 from '../assets/gallery1.png'; // Computer Lab (Big Photo)
// import gallery2 from '../assets/gallery2.png'; // Science Lab
// import gallery3 from '../assets/gallery3.png'; // Cultural
// import gallery4 from '../assets/gallery4.png'; // Sports
---

<section id="gallery" class="relative pt-8 pb-16 md:pt-12 md:pb-24 -mt-16 md:-mt-20 z-40 bg-blue-950 rounded-t-[2.5rem] md:rounded-t-[5rem] overflow-hidden shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
  
  <div class="absolute top-0 center w-full h-full bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-[0.05] pointer-events-none"></div>
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-500/20 rounded-full blur-[100px] pointer-events-none mix-blend-screen"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-amber-500/10 rounded-full blur-[100px] pointer-events-none mix-blend-screen"></div>

  <div class="max-w-7xl mx-auto px-4 relative z-10">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-8 md:mb-12 gap-6">
        <div class="text-left">
            <div class="inline-flex items-center gap-2 mb-2">
                <span class="w-8 h-0.5 bg-amber-500 rounded-full"></span>
                <span class="text-amber-400 font-bold tracking-widest uppercase text-xs">Life at LKEA</span>
            </div>
            <h2 class="text-3xl md:text-5xl font-heading font-black text-white leading-tight">
                Beyond <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-200 to-amber-500">Academics</span>
            </h2>
        </div>

        <a href="/gallery" class="hidden md:inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white font-bold hover:bg-amber-500 hover:border-amber-500 transition-all duration-300 group">
            View Full Gallery
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 grid-rows-[auto_auto_auto] md:grid-rows-2 gap-3 md:gap-4 h-auto md:h-[600px]">
        
        <div class="col-span-2 row-span-2 relative group rounded-2xl md:rounded-3xl overflow-hidden cursor-pointer min-h-[300px] md:min-h-auto bg-blue-900/50 border border-white/5">
            
            <div class="w-full h-full flex items-center justify-center relative">
                <span class="text-6xl opacity-20 grayscale">🖥️</span>
                </div>

            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent opacity-80"></div>
            <div class="absolute bottom-0 left-0 p-4 md:p-8 translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                <span class="bg-amber-500 text-white text-[10px] md:text-xs font-bold px-2 py-1 rounded mb-2 inline-block">Cultural program</span>
                <h3 class="text-lg md:text-2xl font-bold text-white">Saraswati Puja</h3>
            </div>
        </div>

        <div class="col-span-1 row-span-1 relative group rounded-2xl md:rounded-3xl overflow-hidden cursor-pointer min-h-[150px] bg-blue-900/50 border border-white/5">
            
            <div class="w-full h-full flex items-center justify-center">
                <span class="text-4xl opacity-20 grayscale">⚗️</span>
            </div>

            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors"></div>
            <div class="absolute bottom-2 left-2 md:bottom-4 md:left-4">
                <p class="text-white font-bold text-xs md:text-sm drop-shadow-md">Activity</p>
            </div>
        </div>

        <div class="col-span-1 row-span-1 relative group rounded-2xl md:rounded-3xl overflow-hidden cursor-pointer min-h-[150px] bg-blue-900/50 border border-white/5">
            
            <div class="w-full h-full flex items-center justify-center">
                <span class="text-4xl opacity-20 grayscale">🎭</span>
            </div>

            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors"></div>
            <div class="absolute bottom-2 left-2 md:bottom-4 md:left-4">
                <p class="text-white font-bold text-xs md:text-sm drop-shadow-md">Cultural Fest</p>
            </div>
        </div>

        <div class="col-span-2 md:col-span-1 row-span-1 relative group rounded-2xl md:rounded-3xl overflow-hidden cursor-pointer min-h-[150px] bg-blue-900/50 border border-white/5">
            
            <div class="w-full h-full flex items-center justify-center">
                <span class="text-4xl opacity-20 grayscale">⚽</span>
            </div>

            <div class="absolute inset-0 bg-black/40 group-hover:bg-black/20 transition-colors"></div>
            <div class="absolute bottom-2 left-2 md:bottom-4 md:left-4">
                <p class="text-white font-bold text-xs md:text-sm drop-shadow-md">Award session</p>
            </div>
        </div>

        <a href="/gallery" class="hidden md:flex col-span-1 row-span-1 relative group rounded-3xl overflow-hidden cursor-pointer bg-amber-500 flex-col items-center justify-center p-4 text-center hover:bg-amber-600 transition-colors shadow-lg hover:shadow-amber-500/40">
            <span class="text-4xl mb-2 group-hover:scale-110 transition-transform duration-300">📸</span>
            <p class="text-white font-black text-xl leading-tight">500+ <br>Photos</p>
            <p class="text-white/80 text-xs mt-1 group-hover:text-white transition-colors">Explore Gallery →</p>
        </a>

    </div>

    <div class="mt-8 text-center md:hidden">
        <a href="/gallery" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-amber-500 text-white font-bold shadow-lg shadow-amber-500/30">
            View All Photos
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
    </div>

  </div>
</section>