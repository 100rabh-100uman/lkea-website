    </a>

</div>

    <div class="mt-8 text-center md:hidden">
        <a href="/gallery" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-amber-500 text-white font-bold shadow-lg shadow-amber-500/30">
            View All Photos
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
    </div>

  </div>
</section>

<script>
    let player;
    let isVideoReady = false;

    // 1. Inject YouTube API Script dynamically
    const tag = document.createElement('script');
    tag.src = "https://www.youtube.com/iframe_api";
    const firstScriptTag = document.getElementsByTagName('script')[0];
    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

    // 2. Initialize the Player once API is ready
    window.onYouTubeIframeAPIReady = function() {
        player = new YT.Player('yt-player', {
            videoId: 'o6HWUbYJGP8',
            playerVars: {
                'start': 10,             // Start at 10 seconds
                'controls': 0,           // Hide default YT controls
                'disablekb': 1,          // Disable keyboard controls
                'fs': 0,                 // Hide fullscreen button
                'modestbranding': 1,     // Remove YT logo
                'rel': 0,                // Hide related videos
                'mute': 0,               // Start UNMUTED as requested
                'loop': 1,               // Loop the video
                'playlist': 'o6HWUbYJGP8' // Required to loop a single video
            },
            events: {
                'onReady': onPlayerReady
            }
        });
    }

    function onPlayerReady(event) {
        isVideoReady = true;
        const card = document.getElementById('saraswati-card');
        const muteBtn = document.getElementById('mute-btn');
        const fullscreenBtn = document.getElementById('fullscreen-btn');
        const unmuteIcon = document.getElementById('unmute-icon');
        const muteIcon = document.getElementById('mute-icon');

        // DESKTOP: Play on hover, Pause on leave
        card.addEventListener('mouseenter', () => {
            if (window.innerWidth >= 768 && isVideoReady) player.playVideo();
        });
        
        card.addEventListener('mouseleave', () => {
            if (window.innerWidth >= 768 && isVideoReady) player.pauseVideo();
        });

        // MOBILE: Auto-play when visible on screen, Pause when scrolled away
        const observer = new IntersectionObserver((entries) => {
            if (window.innerWidth < 768 && isVideoReady) {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        player.playVideo();
                    } else {
                        player.pauseVideo();
                    }
                });
            }
        }, { threshold: 0.5 }); // Triggers when at least 50% of the card is visible

        if (card) observer.observe(card);

        // Mute / Unmute Toggle Button
        muteBtn.addEventListener('click', (e) => {
            e.stopPropagation(); // Prevents clicking the card background
            if (player.isMuted()) {
                player.unMute();
                muteIcon.classList.add('hidden');
                unmuteIcon.classList.remove('hidden');
            } else {
                player.mute();
                unmuteIcon.classList.add('hidden');
                muteIcon.classList.remove('hidden');
            }
        });

        // Fullscreen Toggle Button
        fullscreenBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const iframe = document.getElementById('yt-player');
            if (iframe.requestFullscreen) {
                iframe.requestFullscreen();
            } else if (iframe.webkitRequestFullscreen) { /* Safari */
                iframe.webkitRequestFullscreen();
            } else if (iframe.msRequestFullscreen) { /* IE11 */
                iframe.msRequestFullscreen();
            }
        });
    }
</script>