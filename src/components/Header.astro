---
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png'; 

const mapLink = "https://maps.app.goo.gl/cEZA3mTEFiQGioS56";
---

<header class="sticky top-0 z-50 flex flex-col shadow-2xl font-sans bg-white">
  
  <div id="top-marquee" class="bg-amber-600 text-white text-[10px] md:text-xs py-1.5 overflow-hidden relative z-50 border-b border-amber-700">
    <div class="whitespace-nowrap animate-marquee flex gap-8 font-bold tracking-wide uppercase items-center">
      <span>📢 Admission Open for 2026-27 session</span> • 
      <span>⚡ Limited Seats</span> • 
      <span>📢 Admission Open for 2026-27 session</span>
      <span>📢Limited seats  </span>
      <span>📢 Admission Open for 2026-27 session</span>
      <span>📢Limited seats  </span>
    </div>
  </div>

  <div class="bg-white py-2 px-3 relative z-40">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      
      <a href="/" class="flex items-center gap-2 group max-w-[65%] md:max-w-none">
        <div class="relative w-10 h-10 md:w-20 md:h-20 shrink-0">
            <div class="w-full h-full bg-white rounded-full p-0.5 md:p-1 border-2 border-amber-500 shadow-sm overflow-hidden">
                <Image 
                    src={logoImg} 
                    alt="Logo" 
                    class="w-full h-full object-contain" 
                    width={200} 
                    format="webp"
                    quality={80}
                    loading="eager" 
                    fetchpriority="high"
                />
            </div>
        </div>
        
       <div class="flex flex-col justify-center relative">
          <span class="font-heading font-black text-[20px] md:text-3xl text-blue-950 uppercase leading-none tracking-tight md:tracking-normal truncate md:overflow-visible -mt-1 md:mt-0">
            Lord Krishna
          </span>

          <span class="text-[12px] md:text-sm font-bold text-amber-600 uppercase leading-none md:leading-tight tracking-tight md:tracking-widest mt-0.5 -mb-1.5 md:mb-0">
            Educational Academy
          </span>
          
          <span class="absolute -bottom-4 md:static text-[7px] md:text-[10px] font-semibold text-slate-500 italic whitespace-nowrap tracking-tighter md:tracking-normal md:whitespace-normal md:mt-0 left-0">
            A unit of Bina Memorial Educational and Charitable Trust
          </span>
          
          <span class="hidden md:block text-[9.5px] font-bold text-slate-400 mt-1 uppercase tracking-wide leading-tight">
            Reg No: SAHPRIVATESCHOOL/L.K.E.A-38/2014 <span class="px-1">|</span> UDISE: 10120404402
          </span>
        </div>
      </a>

      <div class="flex items-center gap-3 md:gap-6">

        <div class="flex items-center gap-3 lg:hidden">
            <a href={mapLink} target="_blank" class="bg-blue-50 p-2 rounded-full border border-blue-100 text-blue-600 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
            </a>
            <a href="tel:9430452463" class="bg-green-50 p-2 rounded-full border border-green-100 text-green-600 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
            </a>
        </div>
        
        <div class="hidden lg:flex items-center gap-6">
            <div class="flex flex-col items-end justify-center h-full text-xs text-slate-700 font-bold border-r pr-6 border-slate-200">
                 <a href="https://www.google.com/search?q=saharsa+bihar" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1 text-red-600 hover:text-amber-600 transition-colors cursor-pointer text-sm pt-1" title="Search Saharsa, Bihar on Google">
                    <span>📍</span> Saharsa, Bihar
                 </a>
            </div>

            <div class="flex flex-col items-stretch justify-center gap-2 min-w-[220px]">
                
                <div class="flex items-center bg-slate-50 border border-slate-200 p-1 pr-3 rounded-full shadow-sm cursor-default">
                    <div class="bg-blue-950 text-white p-1.5 rounded-full shrink-0 mr-2">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    </div>
                    <div class="flex items-center justify-between w-full text-[11px] font-black text-blue-950 tracking-wide">
                        <span>6207-436-091</span>
                        <span class="text-slate-300 font-normal px-1.5">|</span>
                        <span>9430-452-463</span>
                    </div>
                </div>

                <a href="mailto:lkeaSaharsa@gmail.com" class="group flex items-center bg-slate-50 hover:bg-blue-50 border border-slate-200 hover:border-amber-400 p-1 pr-3 rounded-full shadow-sm transition-all duration-300 cursor-pointer">
                    <div class="bg-amber-500 text-white p-1.5 rounded-full shrink-0 mr-2 group-hover:bg-amber-600 transition-colors">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <div class="w-full text-center">
                        <span class="text-[11.5px] font-bold text-blue-950 group-hover:text-amber-700 transition-colors">lkeaSaharsa@gmail.com</span>
                    </div>
                </a>

            </div>

            <a href={mapLink} target="_blank" class="bg-white border-2 border-slate-200 hover:border-blue-500 p-2 rounded-lg shadow-sm hover:shadow-md transition-all group" title="Open Google Maps">
               <img src="https://www.google.com/images/branding/product/2x/maps_96in128dp.png" alt="Map" class="w-8 h-8 object-contain group-hover:scale-110 transition-transform"/>
            </a>

            <a href="/admission" class="bg-blue-900 text-white px-5 py-2.5 rounded-lg font-bold text-xs uppercase shadow-md hover:bg-blue-800 transition flex items-center gap-2">
                <span>✨</span> Admission Open
            </a>
        </div>

        <button id="menu-btn" class="lg:hidden group w-10 h-10 flex flex-col justify-center items-center gap-1.5 focus:outline-none ml-1 z-50 relative">
            <span class="w-6 h-0.5 bg-blue-950 rounded-full transition-all duration-300 origin-center"></span>
            <span class="w-6 h-0.5 bg-blue-950 rounded-full transition-all duration-300 origin-center"></span>
            <span class="w-6 h-0.5 bg-blue-950 rounded-full transition-all duration-300 origin-center"></span>
        </button>

      </div>
    </div>
  </div>

  <div class="hidden lg:block bg-blue-950 border-t border-blue-900 shadow-xl relative z-30">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex justify-between items-center h-10">
        <nav class="flex items-center gap-1 h-full">
            <a href="/" class="h-full flex items-center px-4 text-xs font-bold text-white hover:bg-amber-600 uppercase border-r border-blue-900/50">Home</a>
            <a href="/about" class="h-full flex items-center px-4 text-xs font-bold text-white hover:bg-amber-600 uppercase border-r border-blue-900/50">About School</a>
            
            <div class="relative group h-full">
                <button class="h-full flex items-center px-4 text-xs font-bold text-white hover:bg-amber-600 uppercase tracking-wide transition-colors border-r border-blue-900/50 cursor-pointer">
                   📚 Academics ▾
                </button>
                <div class="absolute top-full left-0 w-64 bg-white shadow-2xl border-t-4 border-amber-600 hidden group-hover:block transition-all transform origin-top z-50">
                    <ul class="py-2">
                        <li><a href="/academics/curriculum" class="block px-4 py-3 text-sm font-bold text-blue-900 hover:bg-blue-50 border-b border-gray-100">📖 Curriculum & Methodology</a></li>
                        <li><a href="/academics/uniform" class="block px-4 py-3 text-sm font-bold text-blue-900 hover:bg-blue-50 border-b border-gray-100">👔 School Uniform</a></li>
                        <li><a href="/academics/books" class="block px-4 py-3 text-sm font-bold text-blue-900 hover:bg-blue-50">📚 Book List & Syllabus</a></li>
                    </ul>
                </div>
            </div>

            <a href="/exam-prep" class="h-full flex items-center px-4 text-xs font-bold text-yellow-400 bg-blue-900/30 hover:bg-amber-600 hover:text-white uppercase tracking-wide transition-colors border-r border-blue-900/50 cursor-pointer">
                🏆 Exam Prep
            </a>

            <a href="/#facilities" class="h-full flex items-center px-4 text-xs font-bold text-white hover:bg-amber-600 uppercase border-r border-blue-900/50">Facilities</a>
            
            <a href="/#FacultySection" class="h-full flex items-center px-4 text-xs font-bold text-white hover:bg-amber-600 uppercase border-r border-blue-900/50">Faculties</a>
            <a href="/hostel" class="h-full flex items-center px-4 text-xs font-bold text-white hover:bg-amber-600 uppercase border-r border-blue-900/50">Hostel</a>
            <a href="/gallery" class="h-full flex items-center px-4 text-xs font-bold text-white hover:bg-amber-600 uppercase border-r border-blue-900/50">Gallery</a>
            <a href="/contact" class="h-full flex items-center px-4 text-xs font-bold text-white hover:bg-amber-600 uppercase border-r border-blue-900/50">Contact us</a>
        </nav>
        <a href="/careers" class="h-full flex items-center gap-2 px-4 bg-amber-600 hover:bg-amber-500 text-white text-xs font-bold uppercase">
            Join as Faculty/Staff
        </a>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-0 z-[100] invisible opacity-0 transition-all duration-300">
      <div class="absolute inset-0 bg-blue-950/60 backdrop-blur-sm" id="menu-backdrop"></div>

      <div class="absolute top-0 right-0 w-[80%] max-w-sm h-full bg-white shadow-2xl transform translate-x-full transition-transform duration-500 cubic-bezier(0.4, 0, 0.2, 1) flex flex-col z-[100]" id="drawer">
          
          <div class="p-4 flex justify-between items-center border-b border-slate-100 bg-white shrink-0">
              <span class="font-black text-lg text-blue-950 tracking-tight">Menu</span>
              <button id="close-menu-btn" class="w-8 h-8 flex items-center justify-center bg-red-50 text-red-500 rounded-full hover:bg-red-100 transition-colors focus:outline-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
          </div>

          <a href="https://www.google.com/search?q=saharsa+bihar" target="_blank" rel="noopener noreferrer" class="bg-blue-50 hover:bg-blue-100 px-4 py-2 border-b border-blue-100 flex items-center gap-2 text-xs text-blue-900 hover:text-amber-600 transition-colors cursor-pointer font-bold shrink-0">
                <span>📍</span> Saharsa, Bihar
          </a>

          <nav class="flex-1 overflow-y-auto p-4 space-y-1 font-bold text-blue-900 text-sm" id="mobile-nav-links">
              <a href="/" class="mobile-link block py-2 border-b border-slate-50 hover:text-amber-600 transition-colors">🏠 Home</a>
              <a href="/about" class="mobile-link block py-2 border-b border-slate-50 hover:text-amber-600 transition-colors">🏫 About School</a>
              
              <div class="border-b border-slate-50 pb-1">
                <p class="mobile-link block py-2 text-blue-950 font-black">📚 Academics</p>
                <div class="pl-4 space-y-1 text-xs text-slate-600 font-semibold border-l-2 border-amber-200 ml-1">
                    <a href="/academics/curriculum" class="mobile-link block py-1.5 hover:text-amber-600">📖 Curriculum & Methodology</a>
                    <a href="/academics/uniform" class="mobile-link block py-1.5 hover:text-amber-600">👔 School Uniform</a>
                    <a href="/academics/books" class="mobile-link block py-1.5 hover:text-amber-600">📚 Book List & Syllabus</a>
                </div>
              </div>

              <a href="/exam-prep" class="mobile-link block py-2 border-b border-slate-50 text-amber-600 font-black">
                  🏆 Exam Preparation
              </a>

              <a href="/#facilities" class="mobile-link block py-2 border-b border-slate-50 hover:text-amber-600">🚌 Facilities</a>
              <a href="/#FacultySection" class="mobile-link block py-2 border-b border-slate-50 hover:text-amber-600">👨‍🏫 Faculties</a>
              <a href="/hostel" class="mobile-link block py-2 border-b border-slate-50 hover:text-amber-600">🛏️ Hostel</a>
              <a href="/gallery" class="mobile-link block py-2 border-b border-slate-50 hover:text-amber-600">🖼️ Gallery</a>
              <a href="/contact" class="mobile-link block py-2 border-b border-slate-50 hover:text-amber-600">📞 Contact Us</a>
              
              <div class="pt-3 space-y-2">
                  <a href="/admission" class="mobile-link block py-2.5 text-white bg-blue-900 rounded-lg text-center shadow-lg font-bold">✨ Apply for Admission</a>
                  <a href="/careers" class="mobile-link block py-2.5 text-blue-950 bg-amber-400 rounded-lg text-center font-bold">Join as Faculty/staff</a>
              </div>
          </nav>

          <div class="p-3 border-t border-slate-100 bg-slate-50 shrink-0">
              <a href="mailto:lkeaSaharsa@gmail.com" class="flex items-center justify-center gap-2 text-xs font-bold text-slate-600 hover:text-amber-600">
                  ✉️ lkeaSaharsa@gmail.com
              </a>
          </div>

      </div>
  </div>

</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const closeMenuBtn = document.getElementById('close-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const drawer = document.getElementById('drawer');
  const backdrop = document.getElementById('menu-backdrop');
  const menuSpans = menuBtn?.querySelectorAll('span');
  const navLinks = document.querySelectorAll('.mobile-link');
  
  // Try to find WhatsApp button by ID first, then by common attributes
  const getWhatsAppBtn = () => {
    return document.getElementById('whatsapp-btn') || 
           document.querySelector('a[href*="wa.me"]') || 
           document.querySelector('a[href*="whatsapp"]');
  };

  let isMenuOpen = false;

  const openMenu = () => {
      isMenuOpen = true;
      mobileMenu.classList.remove('invisible', 'opacity-0');
      drawer.classList.remove('translate-x-full');
      
      // Animate Hamburger
      menuSpans[0].classList.add('rotate-45', 'translate-y-2');
      menuSpans[1].classList.add('opacity-0');
      menuSpans[2].classList.add('-rotate-45', '-translate-y-2');

      // Hide WhatsApp Button
      const waBtn = getWhatsAppBtn();
      if(waBtn) waBtn.style.opacity = '0'; // Hide it
      if(waBtn) waBtn.style.pointerEvents = 'none'; // Disable clicks

      // Staggered Links
      navLinks.forEach((link, index) => {
          setTimeout(() => {
              link.classList.add('slide-in');
          }, index * 30); // Faster stagger (30ms)
      });
  };

  const closeMenu = () => {
      isMenuOpen = false;
      drawer.classList.add('translate-x-full');
      mobileMenu.classList.add('opacity-0');
      
      // Reset Hamburger
      menuSpans[0].classList.remove('rotate-45', 'translate-y-2');
      menuSpans[1].classList.remove('opacity-0');
      menuSpans[2].classList.remove('-rotate-45', '-translate-y-2');

      // Show WhatsApp Button Back
      const waBtn = getWhatsAppBtn();
      if(waBtn) waBtn.style.opacity = '1';
      if(waBtn) waBtn.style.pointerEvents = 'auto';

      // Reset Links
      navLinks.forEach(link => link.classList.remove('slide-in'));

      setTimeout(() => {
          mobileMenu.classList.add('invisible');
      }, 300);
  };

  menuBtn?.addEventListener('click', () => {
      if (isMenuOpen) closeMenu();
      else openMenu();
  });

  backdrop?.addEventListener('click', closeMenu);
  closeMenuBtn?.addEventListener('click', closeMenu);
</script>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    display: inline-flex;
    animation: marquee 20s linear infinite;
  }

  /* Mobile Menu Link Animation */
  .mobile-link {
      opacity: 0;
      transform: translateX(20px);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .mobile-link.slide-in {
      opacity: 1;
      transform: translateX(0);
  }
</style>