---
import { Image } from 'astro:assets';
import campus1 from '../assets/campus1.png';
import schoolPhoto from '../assets/schoolphoto.jpeg';
---

<div class="relative flex items-center bg-blue-950 overflow-hidden pt-2 pb-20 md:pt-4 md:pb-20 min-h-[85vh] md:min-h-0">
  
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <svg class="absolute top-10 left-10 w-12 h-12 text-white/5 animate-float-slow" fill="currentColor" viewBox="0 0 24 24"><path d="M4 6h16v2H4zm2-4h12v2H6zm14 8H4c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-8c0-1.1-.9-2-2-2zm0 10H4v-8h16v8z"/></svg>
    <svg class="absolute bottom-20 left-1/4 w-20 h-20 text-blue-500/10 animate-float-medium" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 14.6c.8 2.3 2.5 4 4.8 4.7-1.4 1.4-3.5 1.7-5.3.7-1.8-1-2.4-3.2-1.3-5.2-.6-.2-1.2-.2-1.8-.2C2.1 14.6 2 15.7 2 16.7c.3 3.5 3.1 6.3 6.6 6.6 1 .1 2.1 0 3.1-1-.1-.6-.1-1.2-.2-1.8-1.9 1.1-4.1.6-5.2-1.3-1-1.8-.7-3.9.7-5.3.2.1.4.3.6.5zm8.9-5.2c-.8-2.3-2.5-4-4.8-4.7 1.4-1.4 3.5-1.7 5.3-.7 1.8 1 2.4 3.2 1.3 5.2.6.2 1.2.2 1.8.2.9 0 1.9-.3 2.8-.7-.3-3.5-3.1-6.3-6.6-6.6-1-.1-2.1 0-3.1 1 .1.6.1 1.2.2 1.8 1.9-1.1 4.1-.6 5.2 1.3 1 1.8.7 3.9-.7 5.3-.2-.1-.4-.3-.6-.5z"/></svg>
    <svg class="absolute top-1/3 right-10 w-8 h-8 text-amber-500/10 animate-float-fast" fill="currentColor" viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
    <svg class="absolute bottom-10 right-1/4 w-16 h-16 text-white/5 animate-float-slow" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3L1 9l11 6 9-4.91V17h2V9M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"/></svg>
  </div>

  <div class="relative z-30 max-w-7xl mx-auto px-4 w-full grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6 items-center">
    
    <div class="text-left md:text-left space-y-4 md:space-y-5 w-full max-w-full overflow-hidden">
      
      <div class="flex flex-col items-start md:items-start gap-3 w-full">
        
        <div id="premium-shloka-box" class="flex flex-col items-start border-l-4 border-amber-500 pl-3 py-1 mb-3 group cursor-pointer animate-fade-in-up w-full">
            <span id="shloka-l1" class="font-heading font-bold text-amber-400 text-[1.1rem] md:text-xl tracking-wide drop-shadow-md transition-opacity duration-300">
                विद्या ददाति विनयं, विनयाद् याति पात्रताम्।
            </span>
            <span id="shloka-l2" class="font-heading font-medium text-blue-100 text-[13px] md:text-[15px] opacity-90 mt-0.5 tracking-wide transition-opacity duration-300">
                पात्रत्वात् धनमाप्नोति, धनात् धर्मं ततः सुखम्॥
            </span>
            
            <span id="shloka-hint-text" class="hidden">Hover to Translate</span>
        </div>

        <div class="inline-flex gap-2 flex-wrap justify-start md:justify-start">
            <span class="bg-indigo-600 border border-indigo-400 text-white text-[10px] md:text-xs font-bold px-2 py-0.5 md:px-3 md:py-1 rounded-full uppercase tracking-wider shadow-md">
              English Medium school
            </span>
            <span class="bg-amber-500 text-white text-[10px] md:text-xs font-bold px-2 py-0.5 md:px-3 md:py-1 rounded-full uppercase tracking-wider">
              🎓 Nursery to Class 8th
            </span>
            <span class="bg-blue-900/80 border border-blue-500 text-blue-100 text-[10px] md:text-xs font-bold px-2 py-0.5 md:px-3 md:py-1 rounded-full uppercase tracking-wider">
              Govt. Regd.
            </span>

            <span class="bg-gradient-to-r from-yellow-200 via-yellow-400 to-yellow-500 text-blue-950 text-[9px] md:text-xs font-black px-2 py-0.5 md:px-3 md:py-1 rounded-full uppercase tracking-wider shadow-[0_0_15px_rgba(234,179,8,0.6)] border border-white/50 flex items-center gap-1 transform hover:scale-105 transition-transform duration-300">
              🏛️ “Serving the community since 2007”
            </span>
        </div>
      </div>

      <div class="flex flex-col gap-2">
          <h1 class="w-full text-4xl sm:text-5xl md:text-3xl lg:text-[2.2rem] xl:text-[2.5rem] font-heading font-black text-white leading-[1.1] md:leading-[1.15] drop-shadow-2xl tracking-tighter pr-4">
            Top Choice for <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-amber-500">Affordable &</span> <br class="hidden md:block" />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-amber-500">Quality Education in Saharsa</span>
          </h1>
          
          <p class="sr-only">
            Lord Krishna Educational Academy is the best English medium school in Saharsa, providing an excellent Nursery to Class 8 school curriculum. As an affordable private school in Saharsa, we offer premium boarding & day school facilities for holistic student development.
          </p>
      </div>

      <div class="text-slate-300 max-w-lg mx-auto md:mx-0 font-medium leading-relaxed bg-blue-900/30 backdrop-blur-sm px-2 py-3 md:p-4 rounded-xl border border-blue-800/50 -ml-1.5 md:ml-0 w-[105%] md:w-auto">
        <p class="text-[10px] md:text-sm text-white mb-1.5 md:mb-2 font-bold uppercase tracking-widest opacity-80 pl-1">
          Why Parents Choose Us:
        </p>
        <ul class="space-y-1.5 md:space-y-2 text-[14px] sm:text-[18px] md:text-base text-left">
          <li class="flex items-center gap-1.5 md:gap-3 whitespace-nowrap tracking-tight md:tracking-normal">
            <div class="bg-green-500/20 p-1 md:p-1.5 rounded-full shrink-0 shadow-inner">
              <svg class="w-2.5 h-2.5 md:w-4 md:h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            Concept Clarity Through Activity-Based Learning
          </li>
          <li class="flex items-center gap-1.5 md:gap-3 whitespace-nowrap tracking-tight md:tracking-normal">
            <div class="bg-green-500/20 p-1 md:p-1.5 rounded-full shrink-0 shadow-inner">
              <svg class="w-2.5 h-2.5 md:w-4 md:h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            Strong Academic Foundation from Early Years
          </li>
          <li class="flex items-center gap-1.5 md:gap-3 whitespace-nowrap tracking-tight md:tracking-normal">
            <div class="bg-green-500/20 p-1 md:p-1.5 rounded-full shrink-0 shadow-inner">
              <svg class="w-2.5 h-2.5 md:w-4 md:h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            Value-Based Education & Disciplined Environment
          </li>
        </ul>
      </div>

      <div class="flex flex-row gap-3 pt-4 pb-2 justify-start md:justify-start w-full relative z-50">
        <div class="relative group flex-1 md:flex-none">
            <div class="absolute -inset-1 bg-gradient-to-r from-amber-600 to-red-600 rounded-xl blur opacity-75 group-hover:opacity-100 transition duration-1000 group-hover:duration-200 animate-tilt"></div>
            <a href="/admission" class="relative block bg-amber-600 hover:bg-amber-700 text-white text-xs md:text-base px-2 py-3 md:px-8 rounded-xl font-bold transition-all text-center shadow-xl transform group-hover:-translate-y-1 whitespace-nowrap">
               👉Apply for Admission
            </a>
        </div>
        <a href="/contact" class="flex-1 md:flex-none px-2 py-3 md:px-6 rounded-xl border-2 border-slate-700 text-white font-bold hover:bg-white hover:text-blue-950 transition-colors text-center backdrop-blur-sm flex items-center justify-center gap-2 text-xs md:text-base group whitespace-nowrap">
          <span class="group-hover:scale-110 transition-transform">🏫</span> Visit campus
        </a>
      </div>
      
    </div>

    <div class="relative mt-2 md:mt-0 -mx-4 md:mx-0">
       
       <div class="hidden md:flex relative md:absolute md:top-2 md:-right-14 justify-center md:justify-start mb-2 md:mb-0 z-40 px-4 md:px-0">
         <div class="bg-blue-900/40 backdrop-blur-md border border-amber-500/30 rounded-xl py-1.5 px-4 flex items-center justify-start gap-3 shadow-2xl">
             <div class="bg-red-600 rounded-full p-1.5 animate-pulse">
                 <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                 </svg>
             </div>
             <div class="flex flex-col items-start">
                 <span class="text-amber-400 font-black uppercase text-[10px] tracking-widest leading-none">Full campus:</span>
                 <span class="text-white font-bold text-xs md:text-sm leading-tight">
                    24x7 CCTV surveillance
                 </span>
             </div>
         </div>
       </div>

       <div class="relative bg-blue-950 md:rounded-3xl md:p-1 shadow-[0_0_100px_-20px_rgba(251,191,36,0.25),_0_0_40px_-10px_rgba(251,191,36,0.15)] overflow-hidden group md:w-[105%] lg:w-[112%] xl:w-[125%] md:-ml-2 lg:-ml-6 xl:-ml-20">
          
          <div id="hero-slider" class="aspect-[4/3] md:aspect-[1.3/1] lg:aspect-[1.45/1] bg-gradient-to-b from-slate-700 to-slate-800 md:rounded-2xl flex overflow-x-auto snap-x snap-mandatory hide-scrollbar scroll-smooth md:p-1.5 w-full">
            
            <div class="min-w-full h-full relative snap-center flex-shrink-0 overflow-hidden md:rounded-xl">
              <Image src={schoolPhoto} alt="School Campus" class="w-full h-full object-cover transition-all duration-[1000ms] md:rounded-xl border-t border-blue-600/10 md:group-hover:scale-[1.03] group-hover:border-blue-400/70 group-hover:shadow-[inset_0_0_20px_8px_rgba(59,130,246,0.5)]" />
              <div class="absolute inset-0 bg-gradient-to-t from-blue-950/80 via-transparent to-transparent pointer-events-none"></div>
              
              <div class="absolute bottom-4 right-4 bg-white/95 backdrop-blur text-blue-950 px-3 py-1.5 rounded-lg shadow-lg text-xs font-bold border-l-4 border-amber-500 z-10">
                ⭐ Main Campus
              </div>
            </div>

            <div class="min-w-full h-full relative snap-center flex-shrink-0 overflow-hidden md:rounded-xl">
              <Image src={campus1} alt="Boarding & Day School in Saharsa - Campus Facilities" class="w-full h-full object-cover transition-transform duration-[2000ms] group-hover:scale-110" />
              <div class="absolute inset-0 bg-gradient-to-t from-blue-950/80 via-transparent to-transparent pointer-events-none"></div>
              
              <div class="absolute bottom-4 right-4 bg-white/95 backdrop-blur text-blue-950 px-3 py-1.5 rounded-lg shadow-lg text-xs font-bold border-l-4 border-amber-500 z-10">
                🏫 Campus View
              </div>
            </div>

          </div>

          <button type="button" id="slide-prev" aria-label="Previous Slide" class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 bg-white/90 hover:bg-white text-blue-950 p-2 md:p-3 rounded-full shadow-xl backdrop-blur-sm transition-all z-50 md:opacity-0 md:group-hover:opacity-100 cursor-pointer">
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"></path></svg>
          </button>
          
          <button type="button" id="slide-next" aria-label="Next Slide" class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 bg-white/90 hover:bg-white text-blue-950 p-2 md:p-3 rounded-full shadow-xl backdrop-blur-sm transition-all z-50 md:opacity-0 md:group-hover:opacity-100 cursor-pointer">
            <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"></path></svg>
          </button>

       </div>

  </div>
  
  

</div>

<style>
  @keyframes float-slow { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
  @keyframes float-medium { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }
  @keyframes float-fast { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
  .animate-float-slow { animation: float-slow 6s ease-in-out infinite; }
  .animate-float-medium { animation: float-medium 5s ease-in-out infinite; }
  .animate-float-fast { animation: float-fast 4s ease-in-out infinite; }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<script is:inline>
  // Run immediately after rendering
  setTimeout(() => {
    const slider = document.getElementById('hero-slider');
    const btnNext = document.getElementById('slide-next');
    const btnPrev = document.getElementById('slide-prev');
    let autoPlayInterval;

    if(!slider || !btnNext || !btnPrev) return;

    // Scroll Right Logic
    const scrollNext = () => {
      const slideWidth = slider.clientWidth;
      if (slider.scrollLeft + slideWidth >= slider.scrollWidth - 10) {
        // Go back to start
        slider.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        // Move one slide right
        slider.scrollBy({ left: slideWidth, behavior: 'smooth' });
      }
    };

    // Scroll Left Logic
    const scrollPrev = () => {
      const slideWidth = slider.clientWidth;
      if (slider.scrollLeft <= 10) {
        // Go to end
        slider.scrollTo({ left: slider.scrollWidth, behavior: 'smooth' });
      } else {
        // Move one slide left
        slider.scrollBy({ left: -slideWidth, behavior: 'smooth' });
      }
    };

    // Button Clicks
    btnNext.addEventListener('click', (e) => {
      e.preventDefault();
      scrollNext();
      resetTimer(); // Reset timer on manual click
    });

    btnPrev.addEventListener('click', (e) => {
      e.preventDefault();
      scrollPrev();
      resetTimer(); // Reset timer on manual click
    });

    // Auto Play (7 Seconds)
    const startTimer = () => {
      autoPlayInterval = setInterval(scrollNext, 7000); 
    };

    const resetTimer = () => {
      clearInterval(autoPlayInterval);
      startTimer();
    };

    // Start auto-slide
    startTimer();
  }, 100); // 100ms delay ensures Tailwind has finished sizing the layout

// ==========================================
  // 🕉️ SHLOKA TRANSLATION LOGIC (HOVER & TOUCH)
  // ==========================================
  setTimeout(() => {
      const shlokaBox = document.getElementById('premium-shloka-box');
      const textL1 = document.getElementById('shloka-l1');
      const textL2 = document.getElementById('shloka-l2');
      const hintText = document.getElementById('shloka-hint-text');

      if (!shlokaBox) return;

      let hoverCycle = 1; // 1 = Next is Hindi, 2 = Next is English
      let isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);

      // Dictionary of Languages
      const shlokaData = {
          sanskrit: {
              l1: 'विद्या ददाति विनयं, विनयाद् याति पात्रताम्।',
              l2: 'पात्रत्वात् धनमाप्नोति, धनात् धर्मं ततः सुखम्॥',
              hint: isTouchDevice ? 'Tap to Translate' : 'Hover to Translate'
          },
          hindi: {
              l1: 'विद्या से नम्रता आती है, नम्रता से योग्यता मिलती है।',
              l2: 'योग्यता से धन, धन से धर्म, और धर्म से सुख मिलता है॥',
              hint: 'Hindi Translation'
          },
          english: {
              l1: 'Knowledge gives humility, humility gives character',
              l2: 'Character brings wealth, wealth leads to righteousness & happiness',
              hint: 'English Translation'
          }
      };

      // Initial hint setup based on device
      hintText.innerText = shlokaData.sanskrit.hint;

      // Smooth text transition function
      function applyTranslation(lang) {
          textL1.style.opacity = '0';
          textL2.style.opacity = '0';
          hintText.style.opacity = '0';
          
          setTimeout(() => {
              textL1.innerText = shlokaData[lang].l1;
              textL2.innerText = shlokaData[lang].l2;
              hintText.innerText = shlokaData[lang].hint;
              
              // Formatting adjustments based on language
              if(lang === 'english') {
                  textL1.classList.replace('font-heading', 'font-sans');
                  textL2.classList.replace('font-heading', 'font-sans');
              } else {
                  textL1.classList.replace('font-sans', 'font-heading');
                  textL2.classList.replace('font-sans', 'font-heading');
              }

              textL1.style.opacity = '1';
              textL2.style.opacity = '1';
              hintText.style.opacity = '1';
          }, 200); // 200ms fade out before changing text
      }

      // Logic for Desktop (Hover)
      if (!isTouchDevice) {
          shlokaBox.addEventListener('mouseenter', () => {
              if (hoverCycle === 1) {
                  applyTranslation('hindi');
                  hoverCycle = 2; // Next time it will be English
              } else {
                  applyTranslation('english');
                  hoverCycle = 1; // Next time it will be Hindi
              }
          });

          shlokaBox.addEventListener('mouseleave', () => {
              applyTranslation('sanskrit'); // Reverts to Sanskrit immediately
          });
      } 
      // Logic for Mobile (Tap/Click)
      else {
          let mobileCycle = 0; // 0=San, 1=Hin, 2=Eng
          shlokaBox.addEventListener('click', (e) => {
              e.preventDefault();
              mobileCycle++;
              if (mobileCycle > 2) mobileCycle = 0;
              
              if (mobileCycle === 0) applyTranslation('sanskrit');
              else if (mobileCycle === 1) applyTranslation('hindi');
              else if (mobileCycle === 2) applyTranslation('english');
          });
      }
  }, 200);


</script>