---
import Layout from '../../layouts/layout.astro';
import { Image } from 'astro:assets';

// REPLACE THESE WITH YOUR ACTUAL IMAGE PATHS
// If you don't have images yet, these placeholders will work, but replace them asap!
import regularUniformImg from '../../assets/student.png'; // Replace with lkea-regular-uniform.jpg
import sportsUniformImg from '../../assets/student.png';  // Replace with lkea-sports-uniform.jpg

// SEO Metadata
const pageTitle = "School Uniform & Dress Code | Lord Krishna Educational Academy, Saharsa";
const pageDescription = "Official school uniform details for Lord Krishna Educational Academy (LKEA), Saharsa. View regular and sports dress codes, weekly schedules, guidelines, and authorized shop information.";

// Data: Schedule
const schedule = [
  { day: "Monday", type: "Regular Uniform", class: "bg-blue-50 text-blue-900" },
  { day: "Tuesday", type: "Regular Uniform", class: "bg-blue-50 text-blue-900" },
  { day: "Wednesday", type: "Regular Uniform", class: "bg-blue-50 text-blue-900" },
  { day: "Thursday", type: "Regular Uniform", class: "bg-blue-50 text-blue-900" },
  { day: "Friday", type: "Sports / House Uniform", class: "bg-amber-50 text-amber-900 font-bold" },
  { day: "Saturday", type: "Sports / House Uniform", class: "bg-amber-50 text-amber-900 font-bold" },
];
---

<Layout title={pageTitle} description={pageDescription}>

  <section class="relative bg-blue-950 text-white pt-10 pb-20 md:pt-16 md:pb-28 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#d4a028 1px, transparent 1px); background-size: 30px 30px;"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <div class="flex justify-start -mt-8 mb-4 md:mt-0 md:mb-0 md:absolute md:top-0 md:left-4 z-30">
      <a href="/" class="group flex items-center gap-1.5 px-3 py-1.5 md:px-4 md:py-2 rounded-lg bg-orange-600 hover:bg-orange-700 text-white font-bold transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 md:w-5 md:h-5 group-hover:-translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        <span class="text-xs md:text-sm font-bold">Back</span>
      </a>
    </div>

    <div class="text-center">
      <div class="inline-block bg-amber-500 text-blue-950 font-black px-3 py-1 rounded-sm text-xs mb-4 uppercase tracking-[0.2em] shadow-lg">
        Official Dress Code
      </div>
      <h1 class="text-4xl md:text-6xl font-black mb-4 leading-tight text-white">
        Our School Uniform
      </h1>
      <p class="text-amber-400 text-xl md:text-2xl font-serif italic tracking-wide mb-8">
        "Discipline. Identity. Pride."
      </p>
      <p class="text-blue-100 max-w-2xl mx-auto text-lg leading-relaxed">
        At <span class="text-white font-bold">Lord Krishna Educational Academy</span>, our uniform represents discipline, equality, and unity. It strengthens the identity of our institution and prepares students for a professional future.
      </p>
    </div>
  </section>

  <section class="relative z-20 bg-white pt-10 pb-24 -mt-16 shadow-2xl" style="border-top-left-radius: 50px; border-top-right-radius: 50px;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-blue-950 mb-4">Uniform Variants</h2>
        <div class="w-20 h-1.5 bg-amber-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16">
        
        <div class="group relative bg-slate-50 rounded-[2.5rem] p-6 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-2 bg-blue-900"></div>
          <div class="flex flex-col md:flex-row items-center gap-6">
            <div class="w-full md:w-1/2 overflow-hidden rounded-2xl">
              <Image 
                src={regularUniformImg} 
                alt="LKEA Regular School Uniform Saharsa - Check Shirt and Navy Pant" 
                class="w-full h-64 md:h-80 object-cover group-hover:scale-105 transition-transform duration-500" 
              />
            </div>
            <div class="w-full md:w-1/2 text-left">
              <h3 class="text-2xl font-bold text-blue-950 mb-2">Regular Uniform</h3>
              <p class="text-slate-500 text-sm font-bold uppercase tracking-wider mb-4">Monday – Thursday</p>
              <ul class="space-y-2 text-slate-700 text-sm md:text-base">
                <li class="flex items-center"><span class="text-amber-500 mr-2">✓</span> Check Pattern Shirt</li>
                <li class="flex items-center"><span class="text-amber-500 mr-2">✓</span> Deep Navy Blue Pant/Skirt</li>
                <li class="flex items-center"><span class="text-amber-500 mr-2">✓</span> School Tie & Badge</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="group relative bg-slate-50 rounded-[2.5rem] p-6 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-100 overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-2 bg-amber-500"></div>
          <div class="flex flex-col md:flex-row items-center gap-6">
            <div class="w-full md:w-1/2 overflow-hidden rounded-2xl">
              <Image 
                src={sportsUniformImg} 
                alt="LKEA Sports Uniform Saharsa - T-Shirt and Lower" 
                class="w-full h-64 md:h-80 object-cover group-hover:scale-105 transition-transform duration-500" 
              />
            </div>
            <div class="w-full md:w-1/2 text-left">
              <h3 class="text-2xl font-bold text-blue-950 mb-2">Sports Uniform</h3>
              <p class="text-slate-500 text-sm font-bold uppercase tracking-wider mb-4">Friday – Saturday</p>
              <ul class="space-y-2 text-slate-700 text-sm md:text-base">
                <li class="flex items-center"><span class="text-blue-900 mr-2">✓</span> House Color T-Shirt</li>
                <li class="flex items-center"><span class="text-blue-900 mr-2">✓</span> Comfortable Lower</li>
                <li class="flex items-center"><span class="text-blue-900 mr-2">✓</span> White Sports Shoes</li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="relative z-30 pt-8 pb-10 -mt-16 bg-blue-50" style="border-top-left-radius: 60px; border-top-right-radius: 60px;">

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="mb-16">
        <h3 class="text-2xl md:text-3xl font-bold text-blue-950 mb-8 flex items-center">
          <span class="w-10 h-10 bg-blue-950 text-white rounded-full flex items-center justify-center text-lg font-bold mr-4 shadow-lg shrink-0">1</span>
          Detailed Dress Code
        </h3>

        <div class="bg-white rounded-[2rem] p-6 md:p-10 shadow-lg border border-white mb-8">
          <h4 class="text-lg md:text-2xl font-bold text-blue-900 mb-6 border-b border-slate-100 pb-2">Regular Days (Monday – Thursday)</h4>
          
          <div class="grid grid-cols-2 gap-4 md:gap-x-12">
            <div>
              <span class="block text-amber-500 font-black uppercase text-[10px] md:text-xs tracking-widest mb-3 md:mb-4">For Boys</span>
              <ul class="space-y-3 md:space-y-4">
                {["Check Shirt with School Logo", "Deep Navy Blue Pant", "School Tie & Belt", "Black Formal Shoes & Navy Socks"].map(item => (
                  <li class="flex items-start text-slate-700 font-medium text-xs md:text-base">
                    <svg class="w-4 h-4 md:w-5 md:h-5 text-slate-400 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    <span class="leading-tight">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            <div>
              <span class="block text-amber-500 font-black uppercase text-[10px] md:text-xs tracking-widest mb-3 md:mb-4">For Girls</span>
              <ul class="space-y-3 md:space-y-4">
                {["Check Shirt with School Logo", "Deep Navy Blue Ghaghra (Skirt)", "School Tie & Belt", "Black Formal Shoes & Navy Socks", "Red Ribbon/Band for Hair"].map(item => (
                  <li class="flex items-start text-slate-700 font-medium text-xs md:text-base">
                    <svg class="w-4 h-4 md:w-5 md:h-5 text-slate-400 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    <span class="leading-tight">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-[2rem] p-6 md:p-10 shadow-lg border border-white">
          <h4 class="text-lg md:text-2xl font-bold text-amber-600 mb-6 border-b border-slate-100 pb-2">Activity Days (Friday – Saturday)</h4>
          
          <div class="grid grid-cols-2 gap-4 md:gap-x-12">
            <div>
              <span class="block text-blue-900 font-black uppercase text-[10px] md:text-xs tracking-widest mb-3 md:mb-4">For Boys</span>
              <ul class="space-y-3 md:space-y-4">
                {["School T-Shirt", "Lower / Track Pant", "White Sports Shoes"].map(item => (
                  <li class="flex items-start text-slate-700 font-medium text-xs md:text-base">
                    <svg class="w-4 h-4 md:w-5 md:h-5 text-amber-400 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    <span class="leading-tight">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            <div>
              <span class="block text-blue-900 font-black uppercase text-[10px] md:text-xs tracking-widest mb-3 md:mb-4">For Girls</span>
              <ul class="space-y-3 md:space-y-4">
                {["School T-Shirt", "Grey Lower / Track Pant", "White Sports Shoes & White Ribbon"].map(item => (
                  <li class="flex items-start text-slate-700 font-medium text-xs md:text-base">
                    <svg class="w-4 h-4 md:w-5 md:h-5 text-amber-400 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    <span class="leading-tight">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <div class="mt-10">
          <h3 class="text-2xl md:text-3xl font-bold text-blue-950 mb-8 flex items-center">
            <span class="w-10 h-10 bg-amber-500 text-blue-950 rounded-full flex items-center justify-center text-lg font-bold mr-4 shadow-lg shrink-0">2</span>
            Weekly Schedule
          </h3>

          <div class="bg-white rounded-[2rem] shadow-xl overflow-hidden border border-slate-100">
              <div class="bg-blue-950 px-6 py-4 flex justify-between items-center">
                  <span class="text-white font-bold uppercase text-xs tracking-wider">Day</span>
                  <span class="text-white font-bold uppercase text-xs tracking-wider">Uniform Code</span>
              </div>
            
              <div class="divide-y divide-slate-100">
                  {schedule.map((item) => (
                    <div class={`flex justify-between items-center px-6 py-4 ${item.class.includes('bg-amber') ? 'bg-amber-50/50' : 'bg-white hover:bg-slate-50'}`}>
                      <span class="font-medium text-sm text-slate-700">{item.day}</span>
                      <span class={`font-bold text-sm ${item.type.includes('Sports') ? 'text-amber-600' : 'text-blue-900'}`}>{item.type}</span>
                    </div>
                  ))}
              </div>
            
              <div class="p-4 bg-slate-50 text-center border-t border-slate-100">
                <p class="text-xs text-slate-400 italic font-medium">* ID Card is mandatory on all days.</p>
              </div>
          </div>

          <div class="mt-8 bg-amber-100 rounded-2xl p-6 border border-amber-200 flex items-start">
              <svg class="w-6 h-6 text-amber-600 mr-3 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <div>
                  <h5 class="font-bold text-amber-800 mb-1 text-sm uppercase tracking-wide">Parent's Note</h5>
                  <p class="text-sm text-amber-900 leading-relaxed font-medium">
                    Please ensure uniforms are washed, ironed, and shoes are polished. Personal hygiene is a part of the school's discipline marks.
                  </p>
              </div>
          </div>

        </div>

    </div>
  </section>

  <section class="pt-8 pb-16 md:pt-4 md:pb-24 bg-white relative overflow-hidden">
     <div class="absolute top-0 right-0 w-64 h-64 bg-blue-50 rounded-full -mr-32 -mt-32"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-amber-50 rounded-full -ml-32 -mb-32"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        
        <div>
          <h3 class="text-3xl font-bold text-blue-950 mb-6">Discipline & Guidelines</h3>
          <ul class="space-y-4">
            {[
              "Students must wear a clean and ironed uniform daily.",
              "School ID card is compulsory for entry.",
              "Black shoes must be polished; socks must be elastic.",
              "Hair must be neatly trimmed (boys) or tied (girls).",
              "Nails must be cut short and clean."
            ].map((rule) => (
              <li class="flex items-start bg-slate-50 p-4 rounded-xl border-l-4 border-amber-500 shadow-sm">
                <span class="text-blue-900 font-bold mr-2">⚠</span>
                <span class="text-slate-700 text-sm font-medium">{rule}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="relative">
          <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-amber-500 rounded-2xl blur opacity-25"></div>
          <div class="relative bg-white rounded-2xl p-8 shadow-2xl border border-slate-100 text-center">
            <div class="w-16 h-16 bg-blue-950 text-amber-400 rounded-full flex items-center justify-center text-3xl mx-auto mb-4 shadow-lg">
              🛍️
            </div>
            <h3 class="text-xl font-bold text-slate-400 uppercase tracking-widest text-xs mb-2">Official Uniform Partner</h3>
            <h2 class="text-2xl md:text-3xl font-black text-blue-950 mb-4">Readymade Imporium</h2>
            
            <div class="space-y-2 text-slate-600 mb-8">
              <p class="flex items-center justify-center">
                <svg class="w-5 h-5 text-amber-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Kapra Patti, Saharsa, Bihar – 852201
              </p>
              <p class="flex items-center justify-center">
                <svg class="w-5 h-5 text-amber-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +91 98789 89789
              </p>
            </div>

            <a href="#" class="inline-block bg-blue-950 text-white font-bold py-3 px-8 rounded-full hover:bg-blue-900 transition-transform transform hover:-translate-y-1 shadow-lg">
              Visit Store
            </a>
            <p class="text-xs text-slate-400 mt-4">* Please carry school admission receipt for purchase</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-12 bg-blue-950 text-center">
    <div class="max-w-4xl mx-auto px-4">
      <p class="text-blue-200 italic text-lg md:text-xl">
        "Our uniform is not just a dress code — it reflects our values, discipline, and commitment to excellence."
      </p>
      <div class="mt-12 flex flex-col md:flex-row justify-center gap-6" data-aos="fade-up">
        
        <a href="/academics/curriculum" class="group relative flex items-center justify-center gap-3 bg-gradient-to-r from-amber-400 to-amber-500 text-blue-950 font-black py-4 px-8 rounded-full shadow-[0_0_20px_rgba(245,158,11,0.4)] hover:shadow-[0_0_30px_rgba(245,158,11,0.6)] hover:-translate-y-1 transition-all duration-300 border border-amber-300 text-lg">
           <svg class="w-6 h-6 text-blue-950 group-hover:scale-110 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
           View Curriculum
        </a>

        <a href="/contact" class="group flex items-center justify-center gap-3 bg-transparent border-2 border-amber-400 text-amber-400 font-black py-4 px-8 rounded-full hover:bg-amber-400 hover:text-blue-950 hover:shadow-[0_0_20px_rgba(245,158,11,0.4)] hover:-translate-y-1 transition-all duration-300 text-lg">
           Contact School
           <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>

      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* is:global lagane se ye ab Layout ke footer ko bhi hide karega */
  footer {
    display: none !important;
  }
</style>