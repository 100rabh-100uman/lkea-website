---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
---

<Layout title="Contact Us">

  <div class="relative bg-blue-950 pt-6 pb-40 md:pt-10 md:pb-52 text-center text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#ffffff_1px,transparent_1px)] [background-size:20px_20px]"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-4">
      <div class="flex justify-start mb-4 md:mb-6">
        <a href="/" class="group flex items-center gap-2 text-xs md:text-sm font-bold uppercase tracking-widest text-slate-300 hover:text-amber-500 transition-colors duration-300 bg-white/5 hover:bg-white/10 px-5 py-2.5 rounded-full border border-white/10 hover:border-amber-500/50 backdrop-blur-md w-fit shadow-sm">
          <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back
        </a>
      </div>
        <h1 class="text-4xl md:text-6xl font-heading font-black text-slate-300 uppercase tracking-wider mb-4 drop-shadow-md">
            Get in <span class="text-amber-500">Touch</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-300 font-medium tracking-wide">
            We are here to assist you with admissions, inquiries, and support.
        </p>
    </div>
  </div>

  <div class="bg-slate-50 rounded-t-[3rem] md:rounded-t-[5rem] -mt-24 md:-mt-32 relative z-20 pt-16 md:pt-24 pb-16 shadow-[0_-15px_30px_-15px_rgba(0,0,0,0.2)]">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-3 gap-12 items-start">
      
      <div class="lg:col-span-1 space-y-8">
        
        <div class="bg-white p-8 rounded-2xl shadow-xl border-t-4 border-blue-900 space-y-8 relative overflow-hidden">
            
            <div>
                <p class="text-xs font-bold text-amber-600 uppercase tracking-widest mb-2">📍 Campus Location</p>
                <h3 class="text-lg font-black text-blue-950 mb-2 leading-tight">Lord Krishna Educational Academy</h3>
                <p class="text-slate-600 leading-relaxed font-medium text-sm">
                    Ward No.- 05, Maharshi Mehi Ashram Road<br/>
                    Shivpuri, Saharsa<br/>
                    Bihar - 852201
                </p>
            </div>
            
            <hr class="border-slate-100" />

            <div>
                <p class="text-xs font-bold text-amber-600 uppercase tracking-widest mb-2">📞 click on phone number to call</p>
                <div class="space-y-2">
                    <a href="tel:+916207436091" class="block text-slate-700 font-bold text-lg hover:text-amber-600 md:pointer-events-none md:cursor-text md:hover:text-slate-700 transition-colors">
                        +91 63074 36091
                    </a>
                </div>
            </div>

            <hr class="border-slate-100" />

            <div>
                <p class="text-xs font-bold text-amber-600 uppercase tracking-widest mb-2">✉️ Email Address</p>
                <a href="mailto:lkeasaharsa@gmail.com" class="text-slate-700 font-bold text-base hover:text-blue-600 transition-colors">
                    lkeasaharsa@gmail.com
                </a>
            </div>

            <div class="bg-blue-50 p-4 rounded-xl border border-blue-100 mt-6">
                <p class="text-xs font-bold text-blue-900 uppercase tracking-widest mb-1">🕒 Office Hours</p>
                <p class="text-slate-700 font-semibold text-sm">Mon - Sat: 6:30 AM - 11:30 PM</p>
            </div>
        </div>
      </div>

      <div class="lg:col-span-2">
        <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl border border-slate-100">
            <h2 class="text-3xl font-heading font-black text-blue-950 mb-2">Send an Inquiry</h2>
            <p class="text-slate-500 font-medium mb-8">Fill out the form below and our administrative team will reach out to you shortly.</p>
            
            <form class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2 group">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider group-focus-within:text-amber-600 transition-colors duration-300">Your Name *</label>
                    <input type="text" placeholder="Write full name" oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '');" class="w-full px-4 py-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:outline-none focus:border-amber-500 focus:ring-4 focus:ring-amber-500/20 focus:bg-white focus:-translate-y-1 hover:shadow-sm focus:shadow-[0_8px_30px_rgba(245,158,11,0.15)] transition-all duration-300 text-blue-950 font-bold placeholder:font-medium placeholder:text-slate-400">
                </div>
                <div class="space-y-2 group">
                    <label class="text-xs font-bold text-slate-500 uppercase tracking-wider group-focus-within:text-amber-600 transition-colors duration-300">Phone Number *</label>
                    <input type="tel" placeholder="10-digit mobile number" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);" class="w-full px-4 py-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:outline-none focus:border-amber-500 focus:ring-4 focus:ring-amber-500/20 focus:bg-white focus:-translate-y-1 hover:shadow-sm focus:shadow-[0_8px_30px_rgba(245,158,11,0.15)] transition-all duration-300 text-blue-950 font-bold placeholder:font-medium placeholder:text-slate-400">
                </div>
            </div>

            <div class="space-y-2 group relative">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider group-focus-within:text-amber-600 transition-colors duration-300">Inquiry Type</label>
                <select class="w-full px-4 py-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:outline-none focus:border-amber-500 focus:ring-4 focus:ring-amber-500/20 focus:bg-white focus:-translate-y-1 hover:shadow-sm focus:shadow-[0_8px_30px_rgba(245,158,11,0.15)] transition-all duration-300 text-blue-950 font-bold appearance-none cursor-pointer">
                    <option>Admission Details</option>
                    <option>Fee Structure</option>
                    <option>Hostel Inquiry</option>
                    <option>General Query</option>
                </select>
                <div class="absolute inset-y-0 right-4 top-7 flex items-center pointer-events-none">
                    <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
                </div>
            </div>

            <div class="space-y-2 group">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider group-focus-within:text-amber-600 transition-colors duration-300">Your Message</label>
                <textarea rows="4" placeholder="How can we help you?" class="w-full px-4 py-3 bg-slate-50 border-2 border-slate-100 rounded-xl focus:outline-none focus:border-amber-500 focus:ring-4 focus:ring-amber-500/20 focus:bg-white focus:-translate-y-1 hover:shadow-sm focus:shadow-[0_8px_30px_rgba(245,158,11,0.15)] transition-all duration-300 text-blue-950 font-bold placeholder:font-medium placeholder:text-slate-400 resize-none"></textarea>
            </div>

            <button type="button" class="w-full bg-blue-950 text-white font-bold uppercase tracking-widest py-4 rounded-xl hover:bg-amber-500 hover:shadow-[0_15px_30px_rgba(245,158,11,0.3)] hover:-translate-y-1 transition-all duration-300 mt-4 border-2 border-transparent hover:border-white/20">
                Submit Inquiry
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>

  <div class="w-full h-[400px] md:h-[500px] bg-slate-200 border-t-4 border-amber-500 relative z-10 group overflow-hidden">
    
    <iframe 
      src="https://maps.google.com/maps?q=Lord%20Krishna%20Educational%20Academy,%20Maharshi%20Mehi%20Ashram%20Rd,%20Shivpuri,%20Saharsa,%20Bihar%20852124&t=&z=16&ie=UTF8&iwloc=&output=embed" 
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade"
      class="w-full h-full">
    </iframe>

    <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></div>

    <a 
      href="https://www.google.com/maps/dir/?api=1&destination=Lord+Krishna+Educational+Academy,+Maharshi+Mehi+Ashram+Road,+Saharsa,+Bihar" 
      target="_blank" 
      rel="noopener noreferrer"
      class="absolute bottom-8 md:bottom-12 left-1/2 -translate-x-1/2 bg-white text-blue-950 font-bold px-8 py-4 rounded-full shadow-[0_10px_25px_rgba(0,0,0,0.2)] hover:shadow-[0_15px_35px_rgba(0,0,0,0.3)] hover:-translate-y-1 hover:text-amber-600 transition-all duration-300 flex items-center gap-3 z-20 group-hover:scale-105"
    >
      <span class="text-xl">📍</span>
      <span class="uppercase tracking-widest text-sm whitespace-nowrap">Get Directions</span>
    </a>

  </div>

</Layout>