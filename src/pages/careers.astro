---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Join Our Team | Lord Krishna Educational Academy">
    
    <section class="relative bg-gradient-to-br from-blue-950 via-blue-900 to-blue-950 py-8 md:py-10 overflow-hidden border-b-4 border-amber-500">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#fbbf24 1px, transparent 1px); background-size: 30px 30px;"></div>
        
        <div class="container mx-auto px-4 relative z-10 text-center max-w-3xl">
            <span class="inline-block bg-amber-500/20 text-amber-400 border border-amber-500/30 font-bold text-xs md:text-sm px-4 py-1.5 rounded-full uppercase tracking-widest mb-4">
                Careers at LKEA
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-black text-white leading-tight mb-4 drop-shadow-lg">
                Build the Future <br />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-amber-500">With Us</span>
            </h1>
            <p class="text-blue-100 text-sm md:text-base font-medium leading-relaxed max-w-2xl mx-auto">
                We are always looking for passionate, dedicated, and innovative educators to join our family. Help us shape the minds of tomorrow in a highly disciplined and value-based environment.
            </p>
        </div>
    </section>

    <section class="py-8 md:py-5 bg-slate-50 relative">
        <div class="container mx-auto px-4 max-w-5xl">
            
            <div class="text-center mb-10 md:mb-14">
                <h2 class="text-3xl md:text-4xl font-heading font-bold text-blue-950 mb-3">How to Apply?</h2>
                <div class="w-20 h-1.5 bg-amber-500 mx-auto rounded-full mb-4"></div>
                <p class="text-slate-600 font-medium">Please send us your detailed resume along with your latest certificates. Choose any of the convenient methods below.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
                
                <div class="bg-white rounded-2xl p-8 shadow-xl border border-slate-100 hover:border-amber-400 hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1 group relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50 rounded-bl-full -z-0 group-hover:bg-blue-100 transition-colors"></div>
                    
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center mb-6 shadow-sm">
                            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                        </div>
                        <h3 class="text-xl font-bold text-blue-950 mb-2">Apply via Email</h3>
                        <p class="text-sm text-slate-500 mb-6">Send your updated CV and educational certificates to our official email address. We review applications daily.</p>
                        
                        <a href="mailto:lkeaSaharsa@gmail.com?subject=Job Application - Resume Attached" class="inline-flex items-center gap-2 w-full justify-center bg-blue-950 hover:bg-blue-900 text-white font-bold py-3 px-6 rounded-lg transition-colors shadow-md">
                            Email Resume
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </a>
                        <p class="text-center text-xs font-bold text-slate-400 mt-3">lkeaSaharsa@gmail.com</p>
                    </div>
                </div>

                <div class="bg-white rounded-2xl p-8 shadow-xl border border-slate-100 group relative overflow-hidden transition-all duration-300">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-green-50 rounded-bl-full -z-0 group-hover:bg-green-100 transition-colors"></div>
                    
                    <div class="relative z-10">
                        <div class="w-14 h-14 bg-green-100 text-green-600 rounded-xl flex items-center justify-center mb-6 shadow-sm">
                            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                        </div>
                        <h3 class="text-xl font-bold text-blue-950 mb-2 cursor-default">Apply via WhatsApp</h3>
                        <p class="text-sm text-slate-500 mb-6 cursor-default">Take a clear photo or send a PDF of your resume directly to our official WhatsApp number for a quick response.</p>
                        
                        <a href="https://wa.me/916207436091?text=Hello%20LKEA,%20I%20would%20like%20to%20apply%20for%20a%20teaching/staff%20position.%20Please%20find%20my%20resume%20attached." target="_blank" class="inline-flex items-center gap-2 w-full justify-center bg-green-500 hover:bg-green-600 text-white font-bold py-3 px-6 rounded-lg transition-colors shadow-md">
                            Message on WhatsApp
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </a>
                        <p class="text-center text-xs font-bold text-slate-400 mt-3 cursor-default">+91 6207-436-091</p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section class="py-8 md:py-5 bg-white border-t border-slate-100">
        <div class="container mx-auto px-4 max-w-4xl">
            <div class="bg-gradient-to-r from-amber-500 to-amber-400 rounded-2xl p-1 md:p-1.5 shadow-xl transform transition-transform hover:scale-[1.01] duration-300">
                <div class="bg-blue-950 rounded-xl p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-8 h-full relative overflow-hidden">
                    
                    <div class="absolute -right-10 -top-10 w-40 h-40 border border-amber-500/20 rounded-full opacity-50"></div>
                    <div class="absolute -right-5 -bottom-5 w-20 h-20 border border-amber-500/20 rounded-full opacity-50"></div>

                    <div class="text-center md:text-left relative z-10 w-full md:w-2/3">
                        <span class="text-amber-400 font-bold tracking-widest text-xs uppercase mb-2 block">Direct Contact</span>
                        <h3 class="text-2xl md:text-3xl font-heading font-black text-white mb-2">Speak to the Administration</h3>
                        <p class="text-blue-200 text-sm md:text-base leading-relaxed">
                            Have questions regarding vacancies or the interview process? Feel free to call the School Office or the Principal directly during working hours (9:00 AM to 3:00 PM).
                        </p>
                    </div>
                    
                    <div class="flex flex-col gap-3 w-full md:w-1/3 relative z-10">
                        <a href="tel:+916207436091" class="flex items-center justify-center gap-3 bg-white/10 hover:bg-white/20 border border-white/20 text-white py-3 px-5 rounded-lg backdrop-blur-sm transition-all">
                            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            <span class="font-bold tracking-wide">6207-436-091</span>
                        </a>
                        
                        <a href="tel:+919430452463" class="flex items-center justify-center gap-3 bg-white/10 hover:bg-white/20 border border-white/20 text-white py-3 px-5 rounded-lg backdrop-blur-sm transition-all">
                            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                            <span class="font-bold tracking-wide">9430-452-463</span>
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </section>

</Layout>