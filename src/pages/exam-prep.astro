---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Exam Preparation | Lord Krishna Educational Academy">

    <section class="relative pt-2 pb-32 md:pt-4 md:pb-48 bg-blue-950 overflow-hidden z-10">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[500px] bg-amber-500/10 rounded-full blur-[100px] pointer-events-none z-0"></div>

        <div class="max-w-7xl mx-auto px-4 relative z-10">
            
            <div class="text-center mt-6">
                <div class="inline-flex items-center gap-3 border border-amber-500 bg-blue-950 px-6 py-2 rounded-full mb-8 shadow-[0_0_15px_rgba(245,158,11,0.2)]">
                    <span class="text-amber-400 text-xs md:text-sm animate-pulse">✦</span>
                    <span class="text-amber-400 text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase">Specialized Entrance Coaching</span>
                    <span class="text-amber-400 text-xs md:text-sm animate-pulse">✦</span>
                </div>
                
                <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-black text-white leading-[1.1] mb-6 drop-shadow-2xl tracking-tight">
                    Shaping Children for <br />
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-amber-400 to-amber-500">India's Elite Schools</span>
                </h1>
                
                <p class="text-blue-100 text-sm md:text-lg max-w-3xl mx-auto leading-relaxed font-medium mb-12 drop-shadow-md">
                    "We do not just teach the syllabus; we prepare your child for greatness. A proud legacy of producing top results in the toughest school entrance exams."
                </p>

                <div class="grid grid-cols-3 gap-2 md:gap-8 max-w-3xl mx-auto mb-12">
                    <div class="bg-blue-900 border border-amber-500/40 px-1 py-3 md:px-8 md:py-5 rounded-xl md:rounded-2xl text-center shadow-[0_4px_20px_rgba(0,0,0,0.3)] hover:-translate-y-1 hover:border-amber-400 transition-all duration-300 flex flex-col justify-center">
                        <span class="block text-3xl md:text-4xl font-black text-white mb-1 drop-shadow-md">50+</span>
                        <span class="text-[10px] md:text-xs font-bold text-amber-400 uppercase tracking-widest">Students Selected</span>
                    </div>
                    <div class="bg-blue-900 border border-amber-500/40 px-1 py-3 md:px-8 md:py-5 rounded-xl md:rounded-2xl text-center shadow-[0_4px_20px_rgba(0,0,0,0.3)] hover:-translate-y-1 hover:border-amber-400 transition-all duration-300 flex flex-col justify-center">
                        <span class="block text-3xl md:text-4xl font-black text-white mb-1 drop-shadow-md">Expert</span>
                        <span class="text-[10px] md:text-xs font-bold text-amber-400 uppercase tracking-widest">Dedicated Faculty</span>
                    </div>
                    <div class="bg-blue-900 border border-amber-500/40 px-1 py-3 md:px-8 md:py-5 rounded-xl md:rounded-2xl text-center shadow-[0_4px_20px_rgba(0,0,0,0.3)] hover:-translate-y-1 hover:border-amber-400 transition-all duration-300 flex flex-col justify-center">
                        <span class="block text-3xl md:text-4xl font-black text-white mb-1 drop-shadow-md">Daily</span>
                        <span class="text-[10px] md:text-xs font-bold text-amber-400 uppercase tracking-widest">Mock Practice</span>
                    </div>
                </div>
            </div>

            <div id="jnv-inline-banner" class="hidden w-full bg-gradient-to-br from-blue-900 to-blue-950 border-2 border-amber-400/80 rounded-3xl px-1 py-5 md:p-10 shadow-2xl opacity-0 transform translate-y-4 transition-all duration-700 mt-4 md:mt-8">
                <div class="text-center mb-8">
                    <div class="inline-block bg-amber-500 text-blue-950 font-black px-4 py-1.5 rounded-full text-[10px] md:text-sm mb-4 uppercase tracking-widest">🌟 2025-26 Selections 🌟</div>
                    <h2 class="text-2xl md:text-4xl font-black text-white mb-2">PM SHRI Jawahar Navodaya Vidyalaya</h2>
                </div>
                <div id="inline-students-container" class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-6 pb-4"></div>
            </div>

        </div>
    </section>

    <section class="pt-5 pb-10 md:pt-1 md:pb-2 bg-slate-50 relative z-20 -mt-16 md:-mt-35 rounded-t-[4rem] md:rounded-t-[5rem] shadow-[0_-15px_30px_-15px_rgba(0,0,0,0.1)]">
        <div class="max-w-7xl mx-auto px-4">
            
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-heading font-black text-blue-950 mb-4">Targeted Exam Preparation</h2>
                <div class="w-24 h-1.5 bg-amber-500 mx-auto rounded-full"></div>
                <p class="mt-6 text-slate-600 max-w-2xl mx-auto font-medium">We provide highly focused, syllabus-oriented foundation batches for the following prestigious institutions.</p>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                
                <div class="bg-white rounded-2xl p-8 shadow-lg border-t-4 border-amber-500 hover:-translate-y-2 transition-transform duration-300 group">
                    <div class="w-14 h-14 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:bg-amber-500 group-hover:text-white transition-colors">🏫</div>
                    <h3 class="text-2xl font-bold text-blue-950 mb-3">PM SHRI Jawahar Navodaya Vidyalaya (JNV)</h3>
                    <p class="text-slate-600 mb-4 leading-relaxed text-sm">Securing a seat in JNV guarantees top-tier CBSE education absolutely free. Our specialized coaching focuses on Mental Ability, Arithmetic, and Language skills to ensure your child easily cracks the JNVST.</p>
                    <ul class="space-y-2 text-sm font-bold text-slate-700">
                        <li class="flex items-center gap-2"><span class="text-amber-500">✓</span> Mental Ability Drills</li>
                        <li class="flex items-center gap-2"><span class="text-amber-500">✓</span> Speed Math Techniques</li>
                    </ul>
                </div>

                <div class="bg-white rounded-2xl p-8 shadow-lg border-t-4 border-blue-600 hover:-translate-y-2 transition-transform duration-300 group">
                    <div class="w-14 h-14 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors">🎯</div>
                    <h3 class="text-2xl font-bold text-blue-950 mb-3">Simultala Awasiya Vidyalaya</h3>
                    <p class="text-slate-600 mb-4 leading-relaxed text-sm">Known as the "Toppers' Factory" of Bihar, Simultala requires intense preparation. We provide rigorous training in Science, Math, and Social Studies tailored to the exact pattern of the preliminary and mains exams.</p>
                    <ul class="space-y-2 text-sm font-bold text-slate-700">
                        <li class="flex items-center gap-2"><span class="text-blue-600">✓</span> Pre & Mains Strategy</li>
                        <li class="flex items-center gap-2"><span class="text-blue-600">✓</span> State-Board Aligned Syllabus</li>
                    </ul>
                </div>

                <div class="bg-white rounded-2xl p-8 shadow-lg border-t-4 border-green-600 hover:-translate-y-2 transition-transform duration-300 group">
                    <div class="w-14 h-14 bg-green-100 text-green-600 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:bg-green-600 group-hover:text-white transition-colors">⚔️</div>
                    <h3 class="text-2xl font-bold text-blue-950 mb-3">All India Sainik Schools (AISSEE)</h3>
                    <p class="text-slate-600 mb-4 leading-relaxed text-sm">Preparing future officers for the NDA requires academic excellence and sharp intellect. Our faculty provides intensive coaching for Mathematics, Intelligence, Language, and General Knowledge.</p>
                    <ul class="space-y-2 text-sm font-bold text-slate-700">
                        <li class="flex items-center gap-2"><span class="text-green-600">✓</span> Intelligence & Reasoning Focus</li>
                        <li class="flex items-center gap-2"><span class="text-green-600">✓</span> GK & Current Affairs Updates</li>
                    </ul>
                </div>

                <div class="bg-white rounded-2xl p-8 shadow-lg border-t-4 border-red-600 hover:-translate-y-2 transition-transform duration-300 group">
                    <div class="w-14 h-14 bg-red-100 text-red-600 rounded-xl flex items-center justify-center text-3xl mb-6 group-hover:bg-red-600 group-hover:text-white transition-colors">👑</div>
                    <h3 class="text-2xl font-bold text-blue-950 mb-3">Netarhat Residential School</h3>
                    <p class="text-slate-600 mb-4 leading-relaxed text-sm">A highly prestigious institution with a rich legacy. The entrance test demands deep conceptual clarity. Our dedicated batches ensure students master the subjective and objective testing patterns.</p>
                    <ul class="space-y-2 text-sm font-bold text-slate-700">
                        <li class="flex items-center gap-2"><span class="text-red-600">✓</span> Conceptual Depth</li>
                        <li class="flex items-center gap-2"><span class="text-red-600">✓</span> Previous Years' Question Analysis</li>
                    </ul>
                </div>

            </div>
        </div>
    </section>

    <section class="py-16 md:py-20 bg-white border-t border-slate-100">
        <div class="max-w-7xl mx-auto px-4">
            <div class="bg-blue-950 rounded-3xl p-8 md:p-16 flex flex-col md:flex-row items-center gap-10 md:gap-16 shadow-2xl relative overflow-hidden">
                <div class="absolute right-0 top-0 w-64 h-64 bg-amber-500/10 rounded-full blur-[50px] pointer-events-none"></div>
                
                <div class="w-full md:w-1/3 text-center md:text-left relative z-10">
                    <h2 class="text-3xl md:text-4xl font-heading font-black text-white leading-tight mb-4">How We Guarantee Success</h2>
                    <p class="text-blue-200 text-sm">Our methodology is proven by our past students who are now thriving in these premier institutions.</p>
                </div>

                <div class="w-full md:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-6 relative z-10">
                    <div class="bg-blue-900/50 border border-blue-800 p-5 rounded-xl">
                        <div class="text-amber-400 text-xl mb-2">📚</div>
                        <h4 class="text-white font-bold mb-1">Exclusive Study Material</h4>
                        <p class="text-blue-200 text-xs leading-relaxed">Custom-designed notes that strictly follow the latest exam patterns of JNV and Sainik Schools.</p>
                    </div>
                    <div class="bg-blue-900/50 border border-blue-800 p-5 rounded-xl">
                        <div class="text-amber-400 text-xl mb-2">⏱️</div>
                        <h4 class="text-white font-bold mb-1">Weekly OMR Mock Tests</h4>
                        <p class="text-blue-200 text-xs leading-relaxed">We conduct real-time OMR sheet-based exams to build time management and remove exam fear.</p>
                    </div>
                    <div class="bg-blue-900/50 border border-blue-800 p-5 rounded-xl">
                        <div class="text-amber-400 text-xl mb-2">👨‍🏫</div>
                        <h4 class="text-white font-bold mb-1">Special Doubt Classes</h4>
                        <p class="text-blue-200 text-xs leading-relaxed">Dedicated faculty members to give one-on-one attention to weak areas in Mathematics and Reasoning.</p>
                    </div>
                    <div class="bg-blue-900/50 border border-blue-800 p-5 rounded-xl">
                        <div class="text-amber-400 text-xl mb-2">📈</div>
                        <h4 class="text-white font-bold mb-1">Performance Tracking</h4>
                        <p class="text-blue-200 text-xs leading-relaxed">Regular Parent-Teacher meetings to discuss the child's ranking and improvement areas.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-16 bg-amber-50 text-center">
        <div class="max-w-3xl mx-auto px-4">
            <h2 class="text-2xl md:text-4xl font-black text-blue-950 mb-4">Give Your Child the Competitive Edge</h2>
            <p class="text-slate-600 mb-8 font-medium">Seats in our special Entrance Preparation batches are strictly limited. Enroll your child today to start their journey.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/admission" class="bg-blue-950 text-white px-8 py-4 rounded-xl font-bold shadow-xl hover:bg-amber-600 transition-colors transform hover:-translate-y-1">
                    Apply for Admission Now
                </a>
                <a href="tel:9430452463" class="bg-white text-blue-950 border-2 border-slate-200 px-8 py-4 rounded-xl font-bold shadow-sm hover:border-blue-950 transition-colors flex items-center justify-center gap-2">
                    📞 Call for Counseling
                </a>
            </div>
        </div>
    </section>

    <div id="jnv-popup-overlay" class="fixed inset-0 z-[100] flex justify-center items-start pt-16 px-4 pb-4 bg-blue-950/90 backdrop-blur-sm transition-opacity duration-500 opacity-100 overflow-y-auto">
        
        <div id="jnv-popup-card" class="relative w-full max-w-6xl max-h-[90vh] overflow-y-auto overflow-x-hidden bg-gradient-to-br from-blue-900 to-blue-950 border-2 border-amber-400 rounded-3xl px-2 pt-10 pb-4 md:px-10 md:pt-10 md:pb-2 shadow-[0_0_50px_rgba(245,158,11,0.5)] transition-transform duration-500 scale-100">
            
            <button id="close-jnv-btn" class="absolute top-3 right-3 md:top-5 md:right-5 text-white bg-white/10 hover:bg-red-500 p-2 md:p-3 rounded-full transition-colors z-50 shadow-lg cursor-pointer">
                <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <div class="text-center mb-5 md:mb-8 mt-0">
                <div class="inline-block bg-amber-500 text-blue-950 font-black px-4 py-1.5 rounded-full text-[10px] md:text-sm mb-3 uppercase tracking-widest shadow-lg animate-bounce">🌟 2025-26 Selections 🌟</div>
                <h2 class="text-[17px] sm:text-2xl md:text-4xl lg:text-5xl font-heading font-black text-white mb-1 md:mb-2 whitespace-nowrap tracking-tight overflow-hidden text-ellipsis">PM SHRI Jawahar Navodaya Vidyalaya</h2>
                <p class="text-amber-400 font-bold text-[10px] sm:text-xs md:text-xl tracking-wide whitespace-nowrap overflow-hidden text-ellipsis">Outstanding Performance by LKEA Students! (5 Selected)</p>
            </div>

            <div id="popup-students-container" class="grid grid-cols-2 md:grid-cols-5 gap-3 md:gap-6 pb-0"></div>
        </div>
    </div>
    

</Layout>

<style is:global>
    footer {
        display: none !important;
    }
    
    /* Scrollbar hidden for premium look */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        // --- STUDENT DATA WITH PHOTO PATHS (from public/students/) ---
        const students = [
            { name: "Seema Bharti",   roll: "1045231", photo: "/students/seema.png" },
            { name: "Srishti Kumari", roll: "1045232", photo: "/students/srishti.png" },
            { name: "Ankita Kumari",  roll: "1220726", photo: "/students/ankita.png" },
            { name: "Sonali Kumari",  roll: "1220754", photo: "/students/sonali.png" },
            { name: "Sushant Kumar",  roll: "1045235", photo: "/students/sushant.png" }
        ];

        // --- HTML GENERATOR (Maximized Photo & Vertical lambai) ---
        const generateCards = () => {
            return students.map((s, index) => `
                <div class="bg-blue-950/50 border border-white/10 rounded-2xl px-2 pt-0.5 pb-3 md:p-5 text-center hover:border-amber-400 hover:-translate-y-2 transition-all duration-300 group relative overflow-hidden shadow-lg flex flex-col justify-start items-center">
                    <div class="absolute inset-0 bg-gradient-to-t from-amber-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    
                    <div class="w-36 h-36 md:w-40 md:h-40 mx-auto bg-slate-200 rounded-full border-4 border-amber-400 mt-0 mb-1.5 overflow-hidden shadow-lg relative z-10 flex items-center justify-center">
                        <img 
                          src="${s.photo}" 
                          alt="Photo of ${s.name}" 
                          class="w-full h-full object-cover rounded-full"
                          loading="lazy" 
                        />
                    </div>
                    
                    <h4 class="text-white font-bold text-[13px] sm:text-sm md:text-lg relative z-10 mb-0 whitespace-nowrap overflow-hidden text-ellipsis">${s.name}</h4>
                    
                    <div class="bg-amber-500/20 text-amber-400 text-[10px] sm:text-xs md:text-xs font-bold py-1.5 px-2 mt-0.5 rounded border border-amber-500/30 inline-block relative z-10 w-full whitespace-nowrap">
                        Roll: ${s.roll}
                    </div>
                </div>
            `).join('');
        };


        // Inject data
        document.getElementById('popup-students-container').innerHTML = generateCards();
        document.getElementById('inline-students-container').innerHTML = generateCards();

        // --- SAFE ANIMATION LOGIC ---
        const popupOverlay = document.getElementById('jnv-popup-overlay');
        const popupCard = document.getElementById('jnv-popup-card');
        const inlineBanner = document.getElementById('jnv-inline-banner');
        const closeBtn = document.getElementById('close-jnv-btn');

        if(popupOverlay && inlineBanner) {
            
            // Reusable close function
            const closePopup = () => {
                // Phase 1: Fade out Popup
                popupOverlay.classList.remove('opacity-100');
                popupOverlay.classList.add('opacity-0');
                if(popupCard) {
                    popupCard.classList.remove('scale-100');
                    popupCard.classList.add('scale-95');
                }

                // Phase 2: Switch to Inline Banner safely after fade
                setTimeout(() => {
                    popupOverlay.style.display = 'none'; // Hide overlay completely
                    inlineBanner.classList.remove('hidden'); // Enable Inline Banner in DOM
                    
                    // Tiny delay to allow CSS to process the "un-hide" before animating
                    setTimeout(() => {
                        inlineBanner.classList.remove('opacity-0', 'translate-y-4');
                        inlineBanner.classList.add('opacity-100', 'translate-y-0');
                    }, 50);

                }, 500); // 500ms transition time
            };

            // 1. Close when clicking the 'X' Button
            if(closeBtn) {
                closeBtn.addEventListener('click', closePopup);
            }

            // 2. Close when clicking the blurred background (Overlay)
            popupOverlay.addEventListener('click', (e) => {
                // Check if the actual click was on the overlay background, NOT inside the card
                if(e.target === popupOverlay) {
                    closePopup();
                }
            });
        }
    });
</script>