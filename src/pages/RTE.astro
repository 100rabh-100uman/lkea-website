---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Free RTE Admission Eligibility - Lord Krishna Educational Academy">
    <div class="min-h-screen bg-slate-50 font-sans">

        <div class="sr-only">
            <h1>RTE Admission in Saharsa</h1>
            <p>Looking for Free School Admission Bihar? Lord Krishna Educational Academy offers free education under the Right to Education Act. Find the best RTE School Near Me and secure one of the 25% RTE Seats Saharsa for economically weaker sections (EWS). Apply for Bihar RTE online form today.</p>
        </div>

        <section class="relative bg-blue-950 pt-10 pb-10 md:pt-15 md:pb-15 overflow-hidden rounded-b-[40px] md:rounded-b-[60px] shadow-2xl z-20">
            <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>
            <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-amber-500/10 rounded-full blur-[100px]"></div>
            
            <div class="max-w-4xl mx-auto px-4 relative z-10 text-center">
                <div class="inline-flex items-center gap-2 bg-amber-500/20 border border-amber-500/50 rounded-full px-4 py-1.5 mb-6 shadow-[0_0_15px_rgba(245,158,11,0.3)]">
                    <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
                    <span class="text-amber-400 font-bold uppercase tracking-widest text-[10px] md:text-xs">Bihar Govt. Initiative (25% Reservation)</span>
                </div>
                <h1 class="text-3xl md:text-5xl lg:text-6xl font-heading font-black text-white leading-tight mb-6 drop-shadow-xl">
                    Free Admission Under <br class="hidden md:block">
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-amber-400 to-amber-200">RTE Act - Check Eligibility</span>
                </h1>
                <p class="text-slate-300 md:text-lg leading-relaxed max-w-3xl mx-auto font-medium bg-blue-900/40 p-4 md:p-6 rounded-2xl border border-white/5 backdrop-blur-sm">
                    Under the Right to Education (RTE) Act, 25% seats are reserved for the admission of children in entry-level classes (<strong class="text-white">Nursery to Class 1</strong>), belonging to economically weaker and disadvantaged sections. Eligible students receive <strong class="text-amber-400">100% free education up to Class 8</strong> at Lord Krishna Educational Academy.
                </p>
            </div>
        </section>

        <section class="py-16 md:py-20 max-w-7xl mx-auto px-4 relative z-10 -mt-10">
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                
                <div class="bg-white p-6 rounded-2xl shadow-xl shadow-slate-200/50 border-t-4 border-amber-500 hover:-translate-y-2 transition-transform duration-300">
                    <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-2xl mb-4 border border-amber-200">🎂</div>
                    <h3 class="text-lg font-bold text-blue-950 mb-3">Child Age Criteria</h3>
                    <ul class="space-y-2 text-sm text-slate-600 font-medium">
                        <li class="flex items-center gap-2"><span class="text-green-500">✔</span> <strong>Nursery:</strong> 3–4 Years</li>
                        <li class="flex items-center gap-2"><span class="text-green-500">✔</span> <strong>LKG:</strong> 4–5 Years</li>
                        <li class="flex items-center gap-2"><span class="text-green-500">✔</span> <strong>UKG:</strong> 5-6 Years</li>
                        <li class="flex items-center gap-2"><span class="text-green-500">✔</span> <strong>Class 1:</strong> 6-7 Years</li>
                    </ul>
                    <p class="text-[10px] text-slate-400 mt-3 italic">*Age calculated as of 1 April 2026</p>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-xl shadow-slate-200/50 border-t-4 border-green-500 hover:-translate-y-2 transition-transform duration-300">
                    <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-2xl mb-4 border border-green-200">💰</div>
                    <h3 class="text-lg font-bold text-blue-950 mb-3">Family Income Limit</h3>
                    <p class="text-sm text-slate-600 font-medium leading-relaxed">
                        Annual family income must be <strong class="text-blue-950">below ₹1 Lakh – ₹2 Lakh</strong> (As per Bihar Govt. EWS norms).
                    </p>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-xl shadow-slate-200/50 border-t-4 border-blue-500 hover:-translate-y-2 transition-transform duration-300">
                    <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-2xl mb-4 border border-blue-200">📍</div>
                    <h3 class="text-lg font-bold text-blue-950 mb-3">Residential Criteria</h3>
                    <p class="text-sm text-slate-600 font-medium leading-relaxed">
                        Child must reside within the <strong class="text-blue-950">school's nearby area / ward</strong> (generally within 1 to 3 km radius).
                    </p>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-xl shadow-slate-200/50 border-t-4 border-purple-500 hover:-translate-y-2 transition-transform duration-300">
                    <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-2xl mb-4 border border-purple-200">🛡️</div>
                    <h3 class="text-lg font-bold text-blue-950 mb-3">Eligible Categories</h3>
                    <ul class="space-y-1.5 text-xs text-slate-600 font-medium">
                        <li class="flex items-center gap-2"><span class="text-purple-500">✔</span> EWS (Economically Weaker)</li>
                        <li class="flex items-center gap-2"><span class="text-purple-500">✔</span> SC / ST</li>
                        <li class="flex items-center gap-2"><span class="text-purple-500">✔</span> OBC (Non-Creamy Layer)</li>
                        <li class="flex items-center gap-2"><span class="text-purple-500">✔</span> Orphan / Single Parent</li>
                        <li class="flex items-center gap-2"><span class="text-purple-500">✔</span> Child with Disability</li>
                    </ul>
                </div>

            </div>
        </section>

        <section class="py-12 bg-white border-y border-slate-200">
            <div class="max-w-7xl mx-auto px-4">
                <div class="text-center mb-10">
                    <h2 class="text-2xl md:text-3xl font-black text-blue-950">Required Documents</h2>
                    <p class="text-slate-500 text-sm mt-2">Keep these documents ready for successful registration</p>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                    <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl text-center group hover:border-amber-500 transition-colors">
                        <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">👦</div>
                        <p class="font-bold text-blue-950 text-xs md:text-sm">Child Aadhaar</p>
                    </div>
                    <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl text-center group hover:border-amber-500 transition-colors">
                        <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">👨‍👩‍👦</div>
                        <p class="font-bold text-blue-950 text-xs md:text-sm">Parent Aadhaar</p>
                    </div>
                    <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl text-center group hover:border-amber-500 transition-colors">
                        <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">📄</div>
                        <p class="font-bold text-blue-950 text-xs md:text-sm">Income Certificate</p>
                    </div>
                    <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl text-center group hover:border-amber-500 transition-colors">
                        <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏠</div>
                        <p class="font-bold text-blue-950 text-xs md:text-sm">Residence Proof</p>
                    </div>
                    <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl text-center group hover:border-amber-500 transition-colors">
                        <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">📜</div>
                        <p class="font-bold text-blue-950 text-xs md:text-sm">Caste Certificate <span class="block text-[9px] text-slate-400 font-normal">(If applicable)</span></p>
                    </div>
                    <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl text-center group hover:border-amber-500 transition-colors">
                        <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">👶</div>
                        <p class="font-bold text-blue-950 text-xs md:text-sm">Birth Certificate</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-16 md:py-24 max-w-4xl mx-auto px-4">
            
            <div class="bg-blue-950 rounded-[2rem] p-6 md:p-10 shadow-2xl relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-amber-400 to-amber-600"></div>
                
                <div class="text-center mb-8">
                    <h2 class="text-2xl md:text-4xl font-black text-white">Smart Eligibility Checker</h2>
                    <p class="text-amber-200/80 text-sm mt-2">Find out if your child qualifies in just 30 seconds.</p>
                </div>

                <form id="rte-checker-form" class="space-y-6 relative z-10">
                    <div class="grid md:grid-cols-2 gap-6">
                        
                        <div class="space-y-2">
                            <label class="text-white text-sm font-bold ml-1">Admission Class</label>
                            <select id="child-class" required class="w-full bg-white border border-slate-200 text-blue-950 rounded-xl px-4 py-3 outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 transition-all appearance-none">
                                <option value="" disabled selected>Select Class...</option>
                                <option value="Nursery">Nursery</option>
                                <option value="LKG">LKG</option>
                                <option value="UKG">UKG</option>
                                <option value="Class 1">Class 1</option>
                            </select>
                        </div>

                        <div class="space-y-2">
                            <label class="text-white text-sm font-bold ml-1">Child's Date of Birth</label>
                            <input type="date" id="child-dob" required class="w-full bg-white border border-slate-200 text-blue-950 rounded-xl px-4 py-3 outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 transition-all uppercase">
                            <p class="text-[10px] text-amber-200/80 ml-1 font-medium">Age will be auto-calculated as of 1st April 2026</p>
                        </div>

                        <div class="space-y-2">
                            <label class="text-white text-sm font-bold ml-1">Annual Family Income</label>
                            <select id="family-income" required class="w-full bg-white border border-slate-200 text-blue-950 rounded-xl px-4 py-3 outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 transition-all appearance-none">
                                <option value="" disabled selected>Select Income Range...</option>
                                <option value="below_1">Below ₹1 Lakh</option>
                                <option value="1_to_2">₹1 Lakh to ₹2 Lakh</option>
                                <option value="above_2">Above ₹2 Lakh</option>
                            </select>
                        </div>

                        <div class="space-y-2">
                            <label class="text-white text-sm font-bold ml-1">Distance from School</label>
                            <select id="distance" required class="w-full bg-white border border-slate-200 text-blue-950 rounded-xl px-4 py-3 outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 transition-all appearance-none">
                                <option value="" disabled selected>Select Distance...</option>
                                <option value="0_1">0 - 1 km</option>
                                <option value="1_3">1 - 3 km</option>
                                <option value="above_3">More than 3 km</option>
                            </select>
                        </div>

                        <div class="md:col-span-2 space-y-2 mb-4">
                            <label class="text-white text-sm font-bold ml-1">Social Category</label>
                            <select id="category" required class="w-full bg-white border border-slate-200 text-blue-950 rounded-xl px-4 py-3 outline-none focus:border-amber-500 focus:ring-1 focus:ring-amber-500 transition-all appearance-none">
                                <option value="" disabled selected>Select Category...</option>
                                <option value="SC_ST">SC / ST</option>
                                <option value="OBC_NCL">OBC (Non-Creamy Layer)</option>
                                <option value="EWS">General (EWS - Economically Weaker Section)</option>
                                <option value="Orphan_Disabled">Orphan / Single Parent / Child with Disability</option>
                                <option value="General">General (Non-EWS)</option>
                            </select>
                        </div>

                        <div class="md:col-span-2 space-y-4 mb-4 pt-4 border-t border-blue-800/50">
                            <label class="text-white text-sm font-bold ml-1">Check if you have these Required Documents</label>
                            <div class="grid md:grid-cols-2 gap-4 text-slate-300">
                                <label class="flex items-center gap-3 bg-white border border-slate-200 p-4 rounded-xl text-blue-950 group hover:border-amber-500 transition-colors">
                                    <input type="checkbox" id="doc-child-aadhaar" class="h-5 w-5 rounded border-gray-300 text-amber-500 focus:ring-amber-500 accent-amber-500">
                                    Child Aadhaar
                                </label>
                                <label class="flex items-center gap-3 bg-white border border-slate-200 p-4 rounded-xl text-blue-950 group hover:border-amber-500 transition-colors">
                                    <input type="checkbox" id="doc-parent-aadhaar" class="h-5 w-5 rounded border-gray-300 text-amber-500 focus:ring-amber-500 accent-amber-500">
                                    Parent Aadhaar
                                </label>
                                <label class="flex items-center gap-3 bg-white border border-slate-200 p-4 rounded-xl text-blue-950 group hover:border-amber-500 transition-colors">
                                    <input type="checkbox" id="doc-income" class="h-5 w-5 rounded border-gray-300 text-amber-500 focus:ring-amber-500 accent-amber-500">
                                    Income Certificate
                                0</label>
                                <label class="flex items-center gap-3 bg-white border border-slate-200 p-4 rounded-xl text-blue-950 group hover:border-amber-500 transition-colors">
                                    <input type="checkbox" id="doc-residence" class="h-5 w-5 rounded border-gray-300 text-amber-500 focus:ring-amber-500 accent-amber-500">
                                    Residence Proof
                                </label>
                                <label class="flex items-center gap-3 bg-white border border-slate-200 p-4 rounded-xl text-blue-950 group hover:border-amber-500 transition-colors">
                                    <input type="checkbox" id="doc-caste" class="h-5 w-5 rounded border-gray-300 text-amber-500 focus:ring-amber-500 accent-amber-500">
                                    Caste Certificate (if applicable)
                                </label>
                                <label class="flex items-center gap-3 bg-white border border-slate-200 p-4 rounded-xl text-blue-950 group hover:border-amber-500 transition-colors">
                                    <input type="checkbox" id="doc-birth" class="h-5 w-5 rounded border-gray-300 text-amber-500 focus:ring-amber-500 accent-amber-500">
                                    Birth Certificate
                                </label>
                            </div>
                        </div>

                    </div>

                    <button type="submit" class="w-full mt-6 bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-400 hover:to-amber-500 text-blue-950 text-lg font-black py-4 rounded-xl shadow-[0_0_20px_rgba(245,158,11,0.4)] transform transition hover:-translate-y-1">
                        Check My Eligibility Now 🚀
                    </button>
                </form>

                <div id="result-container" class="hidden mt-8 pt-8 border-t border-blue-800/50">
                    
                    <div id="loading-state" class="hidden flex-col items-center justify-center py-8 text-center">
                        <div class="relative w-16 h-16 mb-4">
                            <div class="absolute inset-0 rounded-full border-4 border-slate-700"></div>
                            <div class="absolute inset-0 rounded-full border-4 border-amber-500 border-t-transparent animate-spin"></div>
                        </div>
                        <h3 class="text-xl font-bold text-white mb-1">Analyzing Government Criteria...</h3>
                        <p class="text-amber-200/80 text-sm animate-pulse">Please wait while we check your eligibility securely.</p>
                    </div>

                    <div id="eligible-result" class="hidden bg-emerald-500/10 border border-emerald-500/30 rounded-2xl p-6 text-center">
                        <div class="w-16 h-16 bg-emerald-500 rounded-full flex items-center justify-center text-white text-3xl mx-auto mb-4 shadow-[0_0_20px_rgba(16,185,129,0.5)]">🎉</div>
                        <h3 class="text-2xl font-black text-emerald-400 mb-2">Congratulations!</h3>
                        <p class="text-slate-200 mb-6">Based on your details, your child appears <strong class="text-white">Eligible</strong> under the RTE Admission Scheme.</p>
                        <a href="https://gyandeep-rte.bihar.gov.in/" target="_blank" class="inline-block bg-emerald-500 hover:bg-emerald-600 text-white font-bold px-8 py-3 rounded-xl shadow-lg transition-transform hover:-translate-y-1">
                            👉 Apply on Gyandeep Portal (Govt.)
                        </a>

                        <div class="mt-8 pt-6 border-t border-emerald-500/20">
                            <div class="bg-gradient-to-r from-blue-900/80 to-slate-900/80 border border-amber-500/30 p-5 rounded-xl flex flex-col md:flex-row items-center justify-between gap-4 relative overflow-hidden group shadow-2xl">
                                <div class="absolute inset-0 bg-amber-500/5 group-hover:bg-amber-500/10 transition-colors duration-500 pointer-events-none"></div>
                                
                                <div class="text-left flex items-start gap-4 relative z-10">
                                    <div class="w-12 h-12 bg-amber-500/20 border border-amber-500/50 rounded-full flex items-center justify-center text-2xl shrink-0 animate-pulse shadow-[0_0_15px_rgba(245,158,11,0.4)]">
                                        👩‍💻
                                    </div>
                                    <div>
                                        <h4 class="text-lg font-bold text-amber-400 leading-tight">Need Help with Online Form?</h4>
                                        <p class="text-slate-300 text-xs md:text-sm mt-1">We will help you fill the Gyandeep Portal form. Bring your documents to campus or call us for guidance.</p>
                                    </div>
                                </div>

                                <div class="relative z-10 shrink-0 w-full md:w-auto flex flex-col md:flex-row gap-2">
                                    <a href="tel:9430452463" class="flex-1 flex items-center justify-center gap-2 bg-white text-blue-950 font-black px-5 py-2.5 rounded-lg hover:bg-amber-400 transition-colors shadow-lg text-sm whitespace-nowrap">
                                        📞 94304 52463
                                    </a>
                                    <a href="tel:6207436091" class="flex-1 flex items-center justify-center gap-2 bg-slate-800 border border-slate-600 text-white font-bold px-5 py-2.5 rounded-lg hover:bg-slate-700 transition-colors text-sm shadow-lg whitespace-nowrap">
                                        📞 6207 436091
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="not-eligible-result" class="hidden bg-rose-500/10 border border-rose-500/30 rounded-2xl p-6 text-center">
                        <div class="w-16 h-16 bg-rose-500/20 rounded-full flex items-center justify-center text-rose-500 text-3xl mx-auto mb-4">⚠️</div>
                        <h3 class="text-2xl font-black text-rose-400 mb-2">Notice</h3>
                        <p class="text-slate-200 mb-6 leading-relaxed">Based on the provided details, your child <strong class="text-white">may not qualify</strong> under the strict RTE criteria (Age/Income/Distance mismatch or lack of documents). <br> However, you can still provide them with quality education!</p>
                        <a href="/admission" class="inline-block bg-white hover:bg-slate-100 text-blue-950 font-bold px-8 py-3 rounded-xl shadow-lg transition-transform hover:-translate-y-1">
                            👉 Apply via General Admission
                        </a>
                    </div>

                </div>
            </div>
        </section>

    </div>

    <script is:inline>
        document.getElementById('rte-checker-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
           // Get Values
            const childClass = document.getElementById('child-class').value;
            const dobInput = document.getElementById('child-dob').value;
            const income = document.getElementById('family-income').value;
            const distance = document.getElementById('distance').value;
            const category = document.getElementById('category').value;

            // 🧠 Auto-Calculate Age exactly as of 1 April 2026
            const dob = new Date(dobInput);
            const targetDate = new Date('2026-04-01');
            let childAge = targetDate.getFullYear() - dob.getFullYear();
            const monthDiff = targetDate.getMonth() - dob.getMonth();
            if (monthDiff < 0 || (monthDiff === 0 && targetDate.getDate() < dob.getDate())) {
                childAge--; // अगर 1 अप्रैल तक जन्मदिन नहीं आया है, तो 1 साल कम कर दो
            }

            let isEligible = true;

            // 1. Check Age Criteria (Simplified)
            // अगर बच्चे की उम्र 3 साल से कम है या 7 साल से ज्यादा है, सिर्फ तभी उसे रोकें।
            // 3 से 7 साल के बीच के सभी बच्चे पास हो जाएंगे, चाहे वो कोई भी क्लास चुनें।
            if (childAge < 3 || childAge > 7) {
                isEligible = false;
            }

            // 2. Check Income Criteria (Must be under 2 Lakhs)
            if (income === 'above_2') {
                if(category !== 'Orphan_Disabled') {
                    isEligible = false;
                }
            }

            // 3. Check Distance Criteria (Must be within 3 km)
            if (distance === 'above_3') isEligible = false;

            // 4. Check Category Criteria (General without EWS is rejected)
            if (category === 'General') isEligible = false;

            // 5. Document Checkbox Verification
            const documents = ['child-aadhaar', 'parent-aadhaar', 'income', 'residence', 'birth'];
            // Cateogry check to ensure it handles if Caste certificate is actually needed or not
            if (category === 'SC_ST' || category === 'OBC_NCL' ) documents.push('caste');

            documents.forEach(doc => {
                const element = document.getElementById(`doc-${doc}`);
                if (!element.checked) {
                    // Document check failure - setting isEligible to false.
                    isEligible = false;
                }
            });

 // Display Logic
            const resultContainer = document.getElementById('result-container');
            const loadingState = document.getElementById('loading-state');
            const eligibleBox = document.getElementById('eligible-result');
            const notEligibleBox = document.getElementById('not-eligible-result');

            // 1. Show Container & Loading Spinner first
            resultContainer.classList.remove('hidden');
            resultContainer.classList.add('animate-fade-in');
            
            eligibleBox.classList.add('hidden');
            notEligibleBox.classList.add('hidden');
            
            loadingState.classList.remove('hidden');
            loadingState.classList.add('flex'); // Use flex for centering

            // Scroll slightly down to show loading animation
            resultContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

            // 2. Simulate "Smart Processing" for 2 Seconds
            setTimeout(() => {
                // Hide Loading State
                loadingState.classList.add('hidden');
                loadingState.classList.remove('flex');

                // Show Actual Result
                if (isEligible) {
                    eligibleBox.classList.remove('hidden');
                } else {
                    notEligibleBox.classList.remove('hidden');
                }
            }, 2000); // 2000 milliseconds = 2 seconds
        });
    </script>

    <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeIn 0.5s ease-out forwards;
        }
    </style>
</Layout>

<style is:global>
  /* is:global lagane se ye ab Layout ke footer ko bhi hide karega */
  footer {
    display: none !important;
  }
</style>