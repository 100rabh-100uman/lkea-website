 <script is:inline>
    
// ==========================================
// 🚀 1. BULLETPROOF NATIVE PDF GENERATOR
// ==========================================
window.triggerNativePDF = function(btnElement, originalBtnText) {
    const printableArea = document.getElementById('printableArea');
    
    // 1. Lock the form to make it look like a document
    printableArea.classList.add('review-mode');
    
    // 2. Add a tiny delay so the CSS 'review-mode' has time to apply visually
    setTimeout(() => {
        // 3. Trigger the browser's native Print/Save as PDF dialog
        window.print();
        
        // 4. Once they close the print dialog, unlock the form
        printableArea.classList.remove('review-mode');
        
        if(btnElement) {
            btnElement.innerHTML = originalBtnText;
            btnElement.disabled = false;
        }

        // 5. Show the success banner
        const msgBox = document.getElementById('pdf-message');
        if(msgBox) {
            msgBox.classList.remove('hidden');
            setTimeout(() => msgBox.classList.add('hidden'), 8000);
        }
    }, 500);
};
// ==========================================
// 🚀 2. FORM REVIEW, EDIT & SUBMIT LOGIC
// ==========================================

// A. Go to Review Mode
window.goToReviewPage = function() {
    const form = document.getElementById('admissionForm');
    if (!form.checkValidity()) { 
        form.reportValidity(); 
        return; 
    }
    document.getElementById('printableArea').classList.add('review-mode');
    document.getElementById('reviewBtn').classList.add('hidden');
    document.getElementById('submitOptions').classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    alert("📄 Review Mode:\nPlease check all details carefully. This is how your final PDF will look before submission.");
};

// B. Return to Edit Mode
window.editForm = function() {
    document.getElementById('printableArea').classList.remove('review-mode');
    document.getElementById('submitOptions').classList.add('hidden');
    document.getElementById('reviewBtn').classList.remove('hidden');
    window.scrollTo({ top: 0, behavior: 'smooth' });
};

// C. Final Submit & Form Lock
window.submitFinalForm = function() {
    const form = document.getElementById('admissionForm');
    const btn = document.getElementById('confirmBtn');
    const originalText = btn.innerHTML;

    // Double check validation
    if (!form.checkValidity()) { 
        form.reportValidity(); 
        return; 
    }

    btn.innerHTML = "<span>⏳</span> Processing & Locking...";
    btn.disabled = true;

    // Temporarily remove review mode so FormData can capture values correctly
    document.getElementById('printableArea').classList.remove('review-mode');
    const formData = new FormData(form);
    document.getElementById('printableArea').classList.add('review-mode');

    // Send data to Web3Forms
    fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData })
    .then(response => {
        if (response.status === 200) {
            
            // 1. Hide buttons & Show Success Message
            document.getElementById('submitOptions').classList.add('hidden');
            const successSection = document.getElementById('successSection');
            if(successSection) {
                successSection.classList.remove('hidden');
                successSection.scrollIntoView({ behavior: 'smooth' });
            }

            // 2. 🚀 PERMANENT FORM LOCK: Makes everything strictly read-only & Disables toggles completely
            form.querySelectorAll('input, select, textarea, label, .cursor-pointer, .group').forEach(el => {
                el.style.pointerEvents = 'none'; 
                if(el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
                    el.readOnly = true; 
                    // 🚀 NEW: Completely disable radios & checkboxes so they can't be toggled by mouse OR keyboard
                    if(el.type === 'radio' || el.type === 'checkbox') el.disabled = true;
                }
            });

            // 3. Trigger the PDF download window immediately
            setTimeout(() => {
                window.triggerNativePDF(btn, originalText);
            }, 1000);

        } else {
            alert("Error submitting to server. Please try again.");
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    })
    .catch(error => {
        alert("Network Error! Please check your connection.");
        btn.disabled = false;
        btn.innerHTML = originalText;
    });
};

// ==========================================
// 🚀 3. RED DOWNLOAD BUTTON (Direct Trigger)
// ==========================================
window.downloadPDF = function(e) {
    if(e) e.preventDefault(); 
    
    const btn = e.currentTarget;
    const originalText = btn.innerHTML;
    
    btn.innerHTML = "<span>⏳</span> Preparing Document...";
    btn.disabled = true;

    window.triggerNativePDF(btn, originalText);
};

    // ==========================================
    // 2. EXISTING FORM LOGIC (Unchanged)
    // ==========================================

   // Admission Type Toggle
    const radioDay = document.getElementById('typeDay');
    const radioHostel = document.getElementById('typeHostel');
    const sectionDay = document.getElementById('sectionDayScholar');
    const sectionHostel = document.getElementById('sectionHostel');

    function handleAdmissionTypeChange() {
        const selectedType = (radioHostel && radioHostel.checked) ? "Hostel (Boarding)" : "Day Scholar";
        if(document.getElementById('printAdmissionTypeValue')) document.getElementById('printAdmissionTypeValue').innerText = selectedType;

        if (radioHostel && radioHostel.checked) {
            // Show Hostel, Hide Day Scholar
            sectionHostel.classList.remove('hidden');
            sectionDay.classList.add('hidden');
            
            // 1. Remove 'required' from Day Scholar fields
            document.querySelectorAll('.transport-radio').forEach(r => r.required = false);
            if(document.getElementById('dayScholarConsent')) document.getElementById('dayScholarConsent').required = false;
            
            // 2. Add 'required' to Hostel fields
            if(document.getElementById('hostelType')) document.getElementById('hostelType').required = true;
            if(document.getElementById('hostelDuration')) document.getElementById('hostelDuration').required = true;
            if(document.getElementById('allergyInput')) document.getElementById('allergyInput').required = true;
            if(document.getElementById('hostelConsent')) document.getElementById('hostelConsent').required = true;
            
        } else {
            // Show Day Scholar, Hide Hostel
            sectionHostel.classList.add('hidden');
            sectionDay.classList.remove('hidden');
            
            // 1. Add 'required' to Day Scholar fields
            document.querySelectorAll('.transport-radio').forEach(r => r.required = true);
            if(document.getElementById('dayScholarConsent')) document.getElementById('dayScholarConsent').required = true;
            
            // 2. Remove 'required' from Hostel fields so they don't block the form silently
            if(document.getElementById('hostelType')) document.getElementById('hostelType').required = false;
            if(document.getElementById('hostelDuration')) document.getElementById('hostelDuration').required = false;
            if(document.getElementById('allergyInput')) document.getElementById('allergyInput').required = false;
            if(document.getElementById('hostelConsent')) document.getElementById('hostelConsent').required = false;
        }
    }
    if(radioDay) radioDay.addEventListener('change', handleAdmissionTypeChange);
    if(radioHostel) radioHostel.addEventListener('change', handleAdmissionTypeChange);
    handleAdmissionTypeChange(); 

    // Previous School Logic (With Smart PDF Page Breaks)
    const radioPrevYes = document.querySelector('input[name="Previous School Status"][value="Yes"]');
    const prevSchoolBox = document.getElementById('previousSchoolDetails');
    
    function togglePreviousSchool() {
        const parentsSection = document.getElementById('parentsDetailsSection');
        
        if (radioPrevYes && radioPrevYes.checked) {
            // Show Previous School Details
            prevSchoolBox.classList.remove('hidden');
            prevSchoolBox.querySelectorAll('input, select').forEach(i => i.required = true);
            
            // 🚀 MAGIC: Push Parents Details to the next page!
            if(parentsSection) parentsSection.classList.add('dynamic-page-break');
        } else {
            // Hide Previous School Details
            prevSchoolBox.classList.add('hidden');
            prevSchoolBox.querySelectorAll('input, select').forEach(i => i.required = false);
            
            // 🚀 MAGIC: Keep Parents Details on the same page!
            if(parentsSection) parentsSection.classList.remove('dynamic-page-break');
        }
    }
    document.querySelectorAll('input[name="Previous School Status"]').forEach(radio => {
        radio.addEventListener('change', togglePreviousSchool);
    });

// Van Logic (Upgraded for Radio Cards)
    const transportRadios = document.querySelectorAll('.transport-radio');
    const vanBox = document.getElementById('vanDetailsBox');
    
    transportRadios.forEach(radio => {
        radio.addEventListener('change', function() {
            if(this.value === 'School Van') {
                vanBox.classList.remove('hidden');
                vanBox.querySelectorAll('input').forEach(i => i.required = true);
            } else {
                vanBox.classList.add('hidden');
                vanBox.querySelectorAll('input').forEach(i => i.required = false);
            }
        });
    });

    // Illness Logic
    document.querySelectorAll('input[name="Illness"]').forEach(radio => {
        radio.addEventListener('change', function() {
            const details = document.getElementById('illnessDetails');
            if(this.value === 'Yes') {
                details.classList.remove('hidden');
                details.required = true;
            } else {
                details.classList.add('hidden');
                details.required = false;
            }
        });
    });

    // Age Calc
    const dobInput = document.getElementById('dobInput');
    const ageOutput = document.getElementById('ageOutput');
    if(dobInput) {
        dobInput.addEventListener('change', function() {
            if(this.value) {
                const dob = new Date(this.value);
                const age = Math.abs(new Date(Date.now() - dob.getTime()).getUTCFullYear() - 1970);
                ageOutput.value = age + " Years";
            }
        });
    }
    if(document.getElementById('appDate')) document.getElementById('appDate').valueAsDate = new Date();
    if(document.getElementById('hostelDecDate')) document.getElementById('hostelDecDate').valueAsDate = new Date();

    // Review & Submit
    window.goToReviewPage = function() {
        const form = document.getElementById('admissionForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }
        document.getElementById('printableArea').classList.add('review-mode');
        document.getElementById('reviewBtn').classList.add('hidden');
        document.getElementById('submitOptions').classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
        alert("📄 Review Mode:\nCheck details. This is how your PDF will look.");
    }
    window.editForm = function() {
        document.getElementById('printableArea').classList.remove('review-mode');
        document.getElementById('submitOptions').classList.add('hidden');
        document.getElementById('reviewBtn').classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    window.submitFinalForm = function() {
        const form = document.getElementById('admissionForm');
        const btn = document.getElementById('confirmBtn');
        const originalText = btn.innerText;
        btn.innerText = "Submitting...";
        btn.disabled = true;

        document.getElementById('printableArea').classList.remove('review-mode');
        const formData = new FormData(form);
        document.getElementById('printableArea').classList.add('review-mode');

        fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData })
        .then(response => {
            if (response.status === 200) {
                document.getElementById('submitOptions').classList.add('hidden');
                document.getElementById('successSection').classList.remove('hidden');
                document.getElementById('successSection').scrollIntoView({ behavior: 'smooth' });
            } else {
                alert("Error submitting. Please try again.");
                btn.disabled = false;
                btn.innerText = originalText;
            }
        })
        .catch(error => {
            alert("Network Error!");
            btn.disabled = false;
            btn.innerText = originalText;
        });
    }

    // Interactive Photo Upload Preview Logic
    window.previewStudentPhoto = function(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('studentPhotoPreview');
                const placeholder = document.getElementById('studentPhotoPlaceholder');
                
                // Show the image and hide the placeholder text
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                placeholder.classList.add('hidden');
            }
            reader.readAsDataURL(file);
        }
    }

    // Guardian Signature Upload Preview Logic
    window.previewSignature = function(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const preview = document.getElementById('signaturePreview');
                const placeholder = document.getElementById('signaturePlaceholder');
                
                // Show the image and hide the placeholder text
                preview.src = e.target.result;
                preview.classList.remove('hidden');
                placeholder.classList.add('hidden');
            }
            reader.readAsDataURL(file);
        }
    }

// Ultimate Aadhaar Auto-Formatting Logic (Astro-Safe)
    document.querySelectorAll('.aadhaar-input').forEach(function(input) {
        input.addEventListener('input', function(e) {
            // 1. Remove everything except numbers
            let rawValue = this.value.replace(/\D/g, '');
            
            // 2. Limit to exactly 12 digits
            rawValue = rawValue.substring(0, 12);
            
            // 3. Rebuild the string with dashes every 4 digits
            let formattedValue = '';
            for (let i = 0; i < rawValue.length; i++) {
                if (i > 0 && i % 4 === 0) {
                    formattedValue += '-';
                }
                formattedValue += rawValue[i];
            }
            
            // 4. Update the input field seamlessly
            this.value = formattedValue;
        });
    });

// ==========================================
    // JEE-STYLE SMART ADDRESS SYSTEM (Open Source APIs)
    // ==========================================
    
    window.indiaLocationData = []; // Store the API data globally

    // 1. Open Source API: Fetch all 28 States & Districts securely via JSDelivr CDN
    fetch('https://cdn.jsdelivr.net/gh/sab99r/Indian-States-And-Districts@master/states-and-districts.json')
        .then(response => response.json())
        .then(data => {
            window.indiaLocationData = data.states;
            const preState = document.getElementById('pre_state');
            const permState = document.getElementById('perm_state');
            
            // Clear "Loading..." and set default
            preState.innerHTML = '<option value="" disabled selected>Select State</option>';
            permState.innerHTML = '<option value="" disabled selected>Select State</option>';
            
            // Populate all states dynamically
            data.states.forEach(item => {
                preState.add(new Option(item.state, item.state));
                permState.add(new Option(item.state, item.state));
            });
        })
        .catch(error => {
            console.error("Error loading States API", error);
            document.getElementById('pre_state').innerHTML = '<option value="" disabled>Error loading states</option>';
            document.getElementById('perm_state').innerHTML = '<option value="" disabled>Error loading states</option>';
        });

    // 2. Auto-Populate District Dropdown when a State is selected
    window.updateDistricts = function(prefix) {
        const stateSelect = document.getElementById(prefix + '_state');
        const districtSelect = document.getElementById(prefix + '_district');
        const selectedState = stateSelect.value;
        
        districtSelect.innerHTML = '<option value="" disabled selected>Select District</option>';
        
        const stateObj = window.indiaLocationData.find(s => s.state === selectedState);
        if (stateObj && stateObj.districts) {
            stateObj.districts.forEach(district => {
                districtSelect.add(new Option(district, district));
            });
        }
    };

    // 3. Indian Postal API: Live PIN Code Recognition
    window.fetchPinDetails = function(inputElement, prefix) {
        let pin = inputElement.value.replace(/[^0-9]/g, '').substring(0, 6);
        inputElement.value = pin;
        
        const districtSelect = document.getElementById(prefix + '_district');
        const stateSelect = document.getElementById(prefix + '_state');
        const loadingIndicator = document.getElementById(prefix + '_loading');

        if (pin.length === 6) {
            loadingIndicator.classList.remove('opacity-0');
            inputElement.classList.replace('bg-blue-50', 'bg-amber-100');
            
            fetch(`https://api.postalpincode.in/pincode/${pin}`)
            .then(response => response.json())
            .then(data => {
                loadingIndicator.classList.add('opacity-0');
                inputElement.classList.replace('bg-amber-100', 'bg-blue-50');
                
                if (data && data[0] && data[0].Status === 'Success') {
                    let fetchedState = data[0].PostOffice[0].State;
                    let fetchedDistrict = data[0].PostOffice[0].District;

                    // Match state name exactly with the JSON API
                    const stateObj = window.indiaLocationData.find(s => s.state.toLowerCase() === fetchedState.toLowerCase());
                    if (stateObj) {
                        stateSelect.value = stateObj.state;
                        window.updateDistricts(prefix); // Load its districts
                    } else {
                        // Fallback if name slightly differs
                        let stateExists = Array.from(stateSelect.options).some(opt => opt.value === fetchedState);
                        if(!stateExists) stateSelect.add(new Option(fetchedState, fetchedState));
                        stateSelect.value = fetchedState;
                        window.updateDistricts(prefix);
                    }

                    // Set district
                    let districtExists = Array.from(districtSelect.options).some(opt => opt.value === fetchedDistrict);
                    if(!districtExists) districtSelect.add(new Option(fetchedDistrict, fetchedDistrict));
                    districtSelect.value = fetchedDistrict;

                    // Green Success Glow
                    districtSelect.classList.add('ring-2', 'ring-green-400', 'bg-green-50');
                    stateSelect.classList.add('ring-2', 'ring-green-400', 'bg-green-50');
                    setTimeout(() => {
                        districtSelect.classList.remove('ring-2', 'ring-green-400', 'bg-green-50');
                        stateSelect.classList.remove('ring-2', 'ring-green-400', 'bg-green-50');
                    }, 1500);
                }
            })
            .catch(() => {
                loadingIndicator.classList.add('opacity-0');
                inputElement.classList.replace('bg-amber-100', 'bg-blue-50');
            });
        }
    };

    // 4. "Same as Present Address" Flawless Copy Logic
    window.copyAddress = function() {
        const isChecked = document.getElementById('sameAddressBtn').checked;
        const fields = ['state', 'district', 'pin', 'address', 'po', 'ps']; 
        
        fields.forEach(f => {
            const preField = document.getElementById('pre_' + f);
            const permField = document.getElementById('perm_' + f);
            
            if (isChecked) {
                if(f === 'state') {
                    let optionExists = Array.from(permField.options).some(opt => opt.value === preField.value);
                    if(!optionExists && preField.value) permField.add(new Option(preField.value, preField.value));
                    permField.value = preField.value;
                    window.updateDistricts('perm'); 
                } 
                else if (f === 'district') {
                    let optionExists = Array.from(permField.options).some(opt => opt.value === preField.value);
                    if(!optionExists && preField.value) permField.add(new Option(preField.value, preField.value));
                    permField.value = preField.value;
                } 
                else {
                    permField.value = preField.value;
                }
                
                permField.style.pointerEvents = 'none';
                permField.classList.add('bg-slate-100', 'text-slate-500');
                permField.classList.remove('bg-white', 'bg-blue-50');
            } else {
                permField.style.pointerEvents = 'auto';
                permField.classList.remove('bg-slate-100', 'text-slate-500');
                if (f === 'pin') permField.classList.add('bg-blue-50');
                else permField.classList.add('bg-white');
                permField.value = ''; 
                if(f === 'district') permField.innerHTML = '<option value="" disabled selected>Select State First</option>';
            }
        });
    };

// Smart Leave Permission Logic (Progressive Disclosure)
    let currentVisitorCount = 1;
    window.revealNextVisitor = function() {
        currentVisitorCount++;
        
        // Reveal the next row
        const nextRow = document.getElementById('visitor-row-' + currentVisitorCount);
        if(nextRow) {
            nextRow.classList.remove('hidden');
        }
        
        // Hide the button if we reach the max limit of 4
        if(currentVisitorCount >= 4) {
            document.getElementById('addVisitorBtn').classList.add('hidden');
        }
    };

    // Make Visitor 1 required ONLY if Hostel is selected
    const hostelTypeInput = document.getElementById('typeHostel');
    const dayTypeInput = document.getElementById('typeDay');
    
    function toggleVisitorRequirement() {
        const v1Inputs = document.querySelectorAll('input[name^="Visitor 1"]');
        if(hostelTypeInput && hostelTypeInput.checked) {
            v1Inputs.forEach(i => i.required = true);
        } else {
            v1Inputs.forEach(i => i.required = false);
        }
    }
    
    if(hostelTypeInput) hostelTypeInput.addEventListener('change', toggleVisitorRequirement);
    if(dayTypeInput) dayTypeInput.addEventListener('change', toggleVisitorRequirement);


</script>

