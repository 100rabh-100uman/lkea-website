---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets'

import logoImg from '../assets/logo.png';

// 🔴 YOUR WEB3FORMS ACCESS KEY
const access_key = "c4b0799c-0bde-498c-ba74-3b047d8162fc"; 
---



<style is:global>
    /* 👇 Desktop Header Visibility Fix */
    header, nav, .nav-wrapper {
        position: relative !important;
        z-index: 100 !important;
    }

/* 🚀 1. SUPER FORM LOCK: Freezes the entire container against clicks */
    .review-mode {
        pointer-events: none !important;
    }
    /* Rescue interactive action buttons from the freeze */
    .review-mode #submitOptions,
    .review-mode #successSection,
    .review-mode a,
    .review-mode button {
        pointer-events: auto !important;
    }

    /* 2. Review Mode Styling (Form Input Look) */
    .review-mode input, 
    .review-mode select, 
    .review-mode textarea {
        border: none !important;
        background: transparent !important;
        padding: 0 !important;
        font-weight: bold;
        color: #000;
        appearance: none;
        -moz-appearance: none;
        -webkit-appearance: none;
        box-shadow: none !important;
    }

    /* 🚀 FIXED: Restore Radio Buttons & Checkboxes Visibility in PDF */
    .review-mode input[type="radio"], 
    .review-mode input[type="checkbox"] { 
        appearance: auto !important; 
        -moz-appearance: auto !important; 
        -webkit-appearance: auto !important; 
        accent-color: black !important; 
        opacity: 1 !important; /* Prevents fading when form is locked */
    }

    /* Force printers to print locked checkboxes in full dark color */
    @media print {
        input[type="radio"]:disabled, 
        input[type="checkbox"]:disabled,
        .review-mode input[type="radio"], 
        .review-mode input[type="checkbox"] {
            opacity: 1 !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }
    }

    /* Stop animations in review mode */
    .review-mode .animate-pulse {
        animation: none !important;
        opacity: 1 !important;
    }

    /* 👇 BULLETPROOF NATIVE PRINT SETTINGS 🖨️ */
    @media print {
        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            color-adjust: exact !important;
        }

        /* Hide unwanted UI elements during print */
        body > header, 
        body > nav,
        header, nav, footer,
        .sticky, .fixed, 
        .print\:hidden, 
        astro-dev-toolbar,
        a[href="/"] { 
            display: none !important; 
        }

        /* Full width A4 page setup */
        body { 
            background-color: white !important; 
            margin: 0 !important;
            padding: 0 !important;
        }
        
        .min-h-screen {
            min-height: auto !important;
            padding: 0 !important;
            background: white !important;
        }

        #printableArea {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        /* 🚀 FIX: Prevent Badge and UDISE from Disappearing! */
        /* Instead of hiding them, we just disable the blur effect so the print engine doesn't crash */
        .blur, .blur-xl, .backdrop-blur-md {
            filter: none !important;
            -webkit-filter: none !important;
            backdrop-filter: none !important;
            -webkit-backdrop-filter: none !important;
        }

        /* 🚀 FIX: Prevent Header from clipping the Badge during print */
        .overflow-hidden {
            overflow: visible !important;
        }

        /* Prevent cards from cutting in half */
        .rounded-xl {
            page-break-inside: avoid !important;
            break-inside: avoid !important;
        }

        /* 👇 Hide Calendar Icon in Print/Review */
        .review-mode input[type="date"]::-webkit-calendar-picker-indicator,
        .review-mode input[type="date"]::-webkit-inner-spin-button {
            display: none !important;
            -webkit-appearance: none;
        }

        /* 👇 Smart Page Break for Parents Details */
        .dynamic-page-break {
            page-break-before: always !important;
            break-before: page !important;
            margin-top: 20px !important;
        }

        /* Setup A4 Margin */
        @page { 
            margin: 10mm; 
            size: A4 portrait; 
        }
    }

/* 👇 Fix Admission Toggle & Signature Box for Print/Review */
    .print-only-text { display: none; }
    
    .review-mode .interactive-toggle { display: none !important; }
    .review-mode .print-only-text { display: block !important; }
    
    @media print {
        .interactive-toggle { display: none !important; }
        .print-only-text { display: block !important; text-align: center; }
        
        /* Clean up signature upload box so it looks like a physical signing area */
        label[for="guardianSignature"] { 
            border: 1px solid #cbd5e1 !important; 
            background: transparent !important; 
        }
        #signaturePlaceholder span, #signaturePlaceholder p { display: none !important; }
    }

</style>



<Layout title="Admission Form 2026-27">
    
<div class="bg-slate-100 min-h-screen py-6 md:py-12 font-sans">
    <div id="printableArea" class="max-w-4xl mx-auto px-4">
      
      <a href="/" data-html2canvas-ignore="true" class="inline-flex items-center gap-2 text-blue-900 font-bold mb-6 hover:text-amber-600 transition-colors bg-white px-4 py-2 rounded-full shadow-sm border border-slate-200 text-sm">
        <span>←</span> Back to Home
      </a>

      <div class="bg-blue-950 text-white p-6 md:p-10 rounded-t-2xl shadow-2xl border-b-4 border-amber-500 relative overflow-hidden">
        
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 20px 20px;"></div>

        <div class="relative z-10 flex flex-col md:flex-row justify-between items-center text-[10px] md:text-xs font-medium text-blue-200 uppercase tracking-widest mb-8 border-b border-blue-800 pb-4 gap-2">
            <span>Registered by Bihar Government</span>
            <span>Reg No: SAHPRIVATESCHOOL/L.K.E.A-38/2014</span>
        </div>

        <div class="relative z-10 flex flex-col md:flex-row items-center justify-center gap-6 md:gap-8 text-center md:text-left mb-8">
            
            <div class="shrink-0 relative group">
                <div class="absolute inset-0 bg-white/20 blur-xl rounded-full group-hover:bg-white/30 transition-all"></div>
                <Image id="pdf-logo" src={logoImg} alt="School Logo" class="w-24 h-24 object-contain" />

            </div>

            <div class="flex flex-col items-center md:items-start">
                <h1 class="text-3xl md:text-5xl font-heading font-black text-white uppercase tracking-tight leading-none mb-2 drop-shadow-lg">
                    Lord Krishna
                </h1>
                <h2 class="text-xl md:text-3xl font-heading font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-amber-500 uppercase tracking-widest leading-tight mb-3 drop-shadow-sm">
                    Educational Academy
                </h2>
                <p class="text-xs md:text-sm text-blue-200 font-medium italic uppercase tracking-wide">
                    A Unit of Bina Memorial Educational & Charitable Trust
                </p>
                
                <div class="flex items-center gap-2 mt-3 mb-2 opacity-50">
                    <span class="w-8 h-[1px] bg-amber-500"></span>
                    <span class="text-amber-500 text-xs">♦</span>
                    <span class="w-8 h-[1px] bg-amber-500"></span>
                </div>

                <p class="text-sm md:text-base font-bold text-white uppercase tracking-wide">
                    mahershimahi ashram Road, Shivpuri Ward No.-5, Saharsa - 852124 (Bihar)
                </p>
            </div>
        </div>

        <div class="relative z-10 flex flex-col items-center gap-6 mt-6">
            
            <div class="inline-block bg-white/10 backdrop-blur-md border border-white/20 text-amber-300 px-6 py-1 rounded-full shadow-lg">
                <span class="font-bold tracking-widest text-sm md:text-base">UDISE CODE :- 10120404402</span>
            </div>

            <div class="relative cursor-default">
              <div class="absolute -inset-1 bg-gradient-to-r from-amber-400 to-orange-600 rounded-lg blur opacity-50"></div>
    
              <div class="relative bg-gradient-to-r from-amber-500 via-orange-500 to-amber-600 px-8 md:px-12 py-3 md:py-4 rounded-xl border-2 border-amber-300/50 shadow-2xl flex items-center justify-center gap-3">
                   <span class="text-2xl md:text-3xl">📝</span>
                   <div class="text-center">
                      <p class="text-xs md:text-sm font-bold text-amber-100 uppercase tracking-widest mb-0.5">2026-27</p>
                      <h3 class="text-xl md:text-3xl font-heading font-black text-white uppercase tracking-wider drop-shadow-md">
                          Admission Form
                      </h3>
                   </div>
                   <span class="text-2xl md:text-3xl">✨</span>
              </div>
          </div>

        </div>

      </div>

      <form action="https://api.web3forms.com/submit" method="POST" enctype="multipart/form-data" class="bg-white p-4 md:p-10 pt-10 rounded-b-2xl shadow-2xl space-y-8 border border-t-0 border-slate-200 relative top-[-2px]" id="admissionForm">
        
        <div class="mb-10 p-6 md:p-8 bg-white border border-slate-200 rounded-xl shadow-sm relative">
            <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 20px 20px;"></div>
            
            <div class="relative z-10 space-y-4 font-serif text-slate-800">
                <div class="font-bold text-base md:text-lg leading-relaxed">
                    <p>To,</p>
                    <p class="pl-4">The Director,</p>
                    <p class="pl-4 font-black text-blue-950">Lord Krishna Educational Academy.</p>
                </div>
                <p class="font-bold text-base md:text-lg mt-4">Dear Sir,</p>
                <p class="text-sm md:text-base leading-relaxed text-justify text-slate-700">
                    Please admit my ward in your institution. I agree to abide fully by the rules and regulations of the Institute. I solemnly declare that the particulars about my ward given below are true and correct.
                </p>

                <div class="flex flex-row justify-between items-end gap-2 pt-6 mt-4 border-t border-slate-100">
                    
                    <div class="w-[45%]">
                        <label class="block text-[10px] md:text-xs font-bold text-slate-500 uppercase mb-1">Date of Application</label>
                        <input type="date" name="Application Date" id="appDate" required class="w-full bg-slate-50 border-b-2 border-slate-300 focus:border-blue-900 outline-none py-2 px-1 md:px-3 font-bold text-blue-950 rounded-t cursor-not-allowed text-sm">
                    </div>

                    <div class="w-[50%] flex flex-col items-end">
                        <label class="block text-[10px] md:text-xs font-bold text-slate-500 uppercase mb-2 text-right">Guardian's Signature</label>
                        
                        <label for="guardianSignature" class="cursor-pointer w-32 md:w-48 h-16 border-2 border-dashed border-slate-300 flex flex-col items-center justify-center bg-slate-50 text-center relative overflow-hidden group hover:bg-slate-100 transition-colors">
                            <input type="file" id="guardianSignature" accept="image/*" required class="hidden" onchange="previewSignature(event)">
                            <img id="signaturePreview" class="absolute inset-0 w-full h-full object-contain hidden z-10" alt="Signature Preview">
                            <div id="signaturePlaceholder" class="relative z-0">
                                <span class="text-xl opacity-40 block mb-0.5 print:hidden">✍️</span>
                                <p class="text-[8px] md:text-[9px] font-bold text-slate-500 uppercase leading-tight print:hidden">Upload Signature</p>
                            </div>
                            <div class="absolute inset-0 bg-blue-950/70 hidden group-hover:flex items-center justify-center text-white text-[10px] font-bold transition-all opacity-0 group-hover:opacity-100 backdrop-blur-sm z-20 print:hidden">Change</div>
                        </label>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-8 flex flex-col items-center justify-center gap-3">
            
            <div class="print-only-text w-full text-center border-y-2 border-slate-200 py-3 mb-4">
                <h3 class="text-lg font-black text-blue-950 uppercase tracking-widest">
                    Admission Type: <span id="printAdmissionTypeValue" class="text-amber-600">Day Scholar</span>
                </h3>
            </div>

            <div class="interactive-toggle flex flex-col items-center justify-center gap-3 w-full">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-widest">Select Admission Type</label>
                <div class="bg-slate-100 p-1.5 rounded-full inline-flex relative border border-slate-200 shadow-inner">
                    <label class="cursor-pointer relative z-10">
                        <input type="radio" id="typeDay" name="Admission Type" value="Day Scholar" class="peer sr-only" checked>
                        <span class="block px-6 py-2.5 rounded-full text-sm font-bold text-slate-500 transition-all duration-300 peer-checked:bg-blue-950 peer-checked:text-white peer-checked:shadow-lg">
                            Day Scholar
                        </span>
                    </label>

                    <label class="cursor-pointer relative z-10">
                        <input type="radio" id="typeHostel" name="Admission Type" value="Hostel" class="peer sr-only">
                        <span class="block px-6 py-2.5 rounded-full text-sm font-bold text-slate-500 transition-all duration-300 peer-checked:bg-amber-500 peer-checked:text-blue-950 peer-checked:shadow-lg">
                            Hostel (Boarding)
                        </span>
                    </label>
                </div>
            </div>
        </div>

        
        <input type="hidden" name="access_key" value={access_key}>
        <input type="hidden" name="subject" value="New Student Admission - LKEA">
        <input type="hidden" name="from_name" value="LKEA Website">

        <div class="space-y-8 animate-fade-in-up mt-8">
            
            <div>
                <h3 class="flex items-center gap-2 text-blue-950 font-bold text-lg border-b-2 border-amber-500 pb-2 mb-6 mt-4">
                    <span class="bg-amber-100 p-1.5 rounded text-xl">👶</span> Student Personal Details
                </h3>
                
                <div class="flex flex-col md:flex-row print:flex-row gap-6 md:gap-8 items-start">
                    
                    <div class="w-full md:w-1/4 print:w-1/4 flex flex-col items-center md:items-start print:items-start">
                        
                        <div class="w-32 h-40 md:w-36 md:h-44 print:w-32 print:h-40 border-2 border-dashed border-slate-400 bg-slate-50 hover:bg-slate-100 rounded-lg flex flex-col items-center justify-center text-center relative overflow-hidden group cursor-pointer shadow-inner transition-colors" onclick="document.getElementById('studentPhotoInput').click()">
                            <input type="file" id="studentPhotoInput" accept="image/*" required class="hidden" onchange="previewStudentPhoto(event)">
                            <img id="studentPhotoPreview" class="absolute inset-0 w-full h-full object-cover hidden z-10" alt="Student Photo">
                            <div id="studentPhotoPlaceholder" class="p-2 relative z-0">
                                <span class="text-3xl opacity-40 mb-1 block print:hidden">📷</span>
                                <p class="text-[10px] font-bold text-slate-500 uppercase leading-tight print:hidden">Paste / Upload<br>Passport Photo</p>
                                <p class="text-[9px] text-red-500 mt-1 print:hidden">* Required</p>
                            </div>
                            <div class="absolute inset-0 bg-blue-950/70 hidden group-hover:flex items-center justify-center text-white text-xs font-bold transition-all opacity-0 group-hover:opacity-100 backdrop-blur-sm z-20 print:hidden">Change Photo</div>
                        </div>

                    </div>

                    <div class="w-full md:w-3/4 print:w-3/4 flex flex-col gap-5">
                        
                        <div>
                            <label class="text-xs font-bold text-slate-500 uppercase mb-1 block">Student Name <span class="text-red-500">*</span></label>
                            <div class="flex flex-row gap-4">
                                <input type="text" name="Student First Name" required class="w-1/2 bg-slate-50 border border-slate-300 p-3 rounded-lg focus:border-blue-900 font-bold text-blue-950 shadow-sm" placeholder="First Name" oninput="this.value = this.value.replace(/[^A-Za-z]/g, '')">
                                <input type="text" name="Student Last Name" required class="w-1/2 bg-slate-50 border border-slate-300 p-3 rounded-lg focus:border-blue-900 font-bold text-blue-950 shadow-sm" placeholder="Last Name" oninput="this.value = this.value.replace(/[^A-Za-z]/g, '')">
                            </div>
                        </div>

                        <div class="flex flex-row gap-4">
                            <div class="w-1/2">
                                <label class="text-xs font-bold text-slate-500 uppercase mb-1 block">Gender <span class="text-red-500">*</span></label>
                                <select name="Gender" required class="w-full bg-slate-50 border border-slate-300 p-3 rounded-lg focus:border-blue-900 text-blue-950 font-bold shadow-sm">
                                    <option value="" disabled selected>Select</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                            </div>
                            <div class="w-1/2">
                                <label class="text-xs font-bold text-slate-500 uppercase mb-1 block">Blood Group <span class="text-red-500">*</span></label>
                                <select name="Blood Group" required class="w-full bg-slate-50 border border-slate-300 p-3 rounded-lg text-blue-950 font-bold focus:border-blue-900 shadow-sm">
                                    <option value="" disabled selected>Select</option>
                                    <option value="A+">A+</option>
                                    <option value="A-">A-</option>
                                    <option value="B+">B+</option>
                                    <option value="B-">B-</option>
                                    <option value="O+">O+</option>
                                    <option value="O-">O-</option>
                                    <option value="AB+">AB+</option>
                                    <option value="AB-">AB-</option>
                                </select>
                            </div>
                        </div>

                        <div class="flex flex-row gap-4">
                            <div class="w-1/2">
                                <label class="text-xs font-bold text-slate-500 uppercase mb-1 block">Date of Birth (DOB) <span class="text-red-500">*</span></label>
                                <input type="date" name="DOB" id="dobInput" required class="w-full bg-slate-50 border border-slate-300 p-3 rounded-lg focus:border-blue-900 text-blue-950 font-bold shadow-sm">
                            </div>
                            <div class="w-1/2">
                                <label class="text-xs font-bold text-slate-500 uppercase mb-1 block">Age</label>
                                <input type="text" name="Age" id="ageOutput" readonly class="w-full bg-slate-200 border border-slate-300 p-3 rounded-lg text-slate-600 font-bold shadow-inner" placeholder="Auto Calc">
                            </div>
                        </div>

                        <div>
                            <label class="text-xs font-bold text-slate-500 uppercase mb-1 block">Class Applying For <span class="text-red-500">*</span></label>
                            <select name="Class" required class="w-full bg-slate-50 border border-slate-300 p-3 rounded-lg font-bold text-blue-950 focus:border-blue-900 shadow-sm">
                                <option value="" disabled selected>Select Class</option>
                                <option value="Nursery">Nursery</option>
                                <option value="LKG">LKG</option>
                                <option value="UKG">UKG</option>
                                <option value="Class 1">Class 1</option>
                                <option value="Class 2">Class 2</option>
                                <option value="Class 3">Class 3</option>
                                <option value="Class 4">Class 4</option>
                                <option value="Class 5">Class 5</option>
                                <option value="Class 6">Class 6</option>
                                <option value="Class 7">Class 7</option>
                                <option value="Class 8">Class 8</option>
                            </select>
                        </div>
                        
                        <div>
                            <label class="text-xs font-bold text-slate-500 uppercase mb-1 block">Student Aadhaar (Optional)</label>
                            <input type="text" name="Student Aadhaar" class="w-full bg-slate-50 border border-slate-300 p-3 rounded-lg focus:border-blue-900 font-bold text-blue-950 shadow-sm text-center tracking-widest aadhaar-input" placeholder="XXXX-XXXX-XXXX" maxlength="14">
                        </div>

                    </div>

                </div>
            </div>

        <div class="bg-blue-50 p-4 rounded-xl border border-blue-100">
                 <label class="text-xs font-bold text-blue-800 uppercase block mb-2">Has the student studied in a school before? <span class="text-red-500">*</span></label>
                 <div class="flex gap-6 mb-3">
                     <label class="flex items-center gap-2 cursor-pointer">
                         <input type="radio" name="Previous School Status" value="Yes" class="accent-blue-900">
                         <span class="text-sm font-bold text-slate-700">Yes</span>
                     </label>
                     <label class="flex items-center gap-2 cursor-pointer">
                         <input type="radio" name="Previous School Status" value="No (First Admission)" class="accent-blue-900" onchange="togglePreviousSchool()">
                         <span class="text-sm font-bold text-slate-700">No (First Time Admission)</span>
                     </label>
                 </div>
                 
                 <div id="previousSchoolDetails" class="hidden grid md:grid-cols-2 gap-5 animate-fade-in-up mt-4 border-t border-blue-100 pt-5">
                     
                     <div class="md:col-span-2">
                         <label class="text-xs font-bold text-slate-500 uppercase">Previous School Name</label>
                         <input type="text" name="Previous School Name" class="w-full bg-white border border-slate-300 p-3 rounded-lg focus:border-blue-900 font-bold text-blue-950 shadow-sm" placeholder="Enter school name" oninput="this.value = this.value.replace(/[^a-zA-Z ]/g, '')">
                     </div>
                     
                     <div class="md:col-span-2 grid grid-cols-2 gap-5">
                         <div>
                             <label class="text-xs font-bold text-slate-500 uppercase">Studied From Year</label>
                             <input type="text" name="Studied From Year" class="w-full bg-white border border-slate-300 p-3 rounded-lg focus:border-blue-900 font-bold text-blue-950 shadow-sm text-center tracking-widest" placeholder="YYYY" maxlength="4" oninput="let v = this.value.replace(/[^0-9]/g, ''); let cy = new Date().getFullYear(); if(v.length === 4 && parseInt(v) > cy) v = cy.toString(); this.value = v;">
                         </div>
                         
                         <div>
                             <label class="text-xs font-bold text-slate-500 uppercase">To Year</label>
                             <input type="text" name="Studied To Year" class="w-full bg-white border border-slate-300 p-3 rounded-lg focus:border-blue-900 font-bold text-blue-950 shadow-sm text-center tracking-widest" placeholder="YYYY" maxlength="4" oninput="let v = this.value.replace(/[^0-9]/g, ''); let cy = new Date().getFullYear(); if(v.length === 4 && parseInt(v) > cy) v = cy.toString(); this.value = v;">
                         </div>
                     </div>
                     
                     <div class="md:col-span-2">
                         <label class="text-xs font-bold text-slate-500 uppercase">Last Class Passed</label>
                         <select name="Last Class" class="w-full bg-white border border-slate-300 p-3 rounded-lg focus:border-blue-900 text-blue-950 font-bold shadow-sm">
                             <option value="" disabled selected>Select Last Class</option>
                             <option value="Nursery">Nursery</option>
                             <option value="LKG">LKG</option>
                             <option value="UKG">UKG</option>
                             <option value="Class 1">Class 1</option>
                             <option value="Class 2">Class 2</option>
                             <option value="Class 3">Class 3</option>
                             <option value="Class 4">Class 4</option>
                             <option value="Class 5">Class 5</option>
                             <option value="Class 6">Class 6</option>
                             <option value="Class 7">Class 7</option>
                         </select>
                     </div>
                     
                </div>
            
            </div>
        
            <div id="parentsDetailsSection" class="transition-all duration-300 ">
                <h3 class="flex items-center gap-2 text-blue-950 font-bold text-lg border-b-2 border-amber-500 pb-2 mb-6">
                    <span class="bg-amber-100 p-1.5 rounded text-xl">👨‍👩‍👦</span> Parents Details
                </h3>
                
                <div class="flex flex-col print:flex-row md:flex-row gap-6 md:gap-8">
                    
                    <div class="w-full print:w-1/2 md:w-1/2 bg-slate-50 p-5 rounded-xl border border-slate-200 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-1 h-full bg-blue-900"></div>
                        <p class="font-bold text-blue-900 mb-4 border-b border-slate-200 pb-2 flex items-center gap-2">👨 Father's Info</p>
                        
                        <div class="space-y-4">
                            <div>
                                <label class="text-xs font-bold text-slate-500 uppercase mb-1 block">Full Name <span class="text-red-500">*</span></label>
                                <input type="text" name="Father Name" required class="w-full bg-white border border-slate-300 p-3 rounded-lg focus:border-blue-900 font-bold text-blue-950 shadow-sm" placeholder="Father's Name" oninput="this.value = this.value.replace(/[^a-zA-Z ]/g, '')">
                            </div>
                            <div>
